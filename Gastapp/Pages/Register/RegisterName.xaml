<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Gastapp.Pages.Register.RegisterName">
    <Grid
        RowDefinitions="auto, *"
        Padding="30, 20"
        >
        <Label FontSize="30" Text="Dinos, ¿Cual es tu nombre?   ^_^" FontAttributes="Bold"/>

        <VerticalStackLayout Grid.Row="1" VerticalOptions="Center">
            <Entry Keyboard="Text" ReturnType="Done" VerticalOptions="Center" />
            <Label Text="¿Como podemos llamarte?" Padding="0" FontAttributes="Bold"/>
        </VerticalStackLayout>

    </Grid>
</ContentView>