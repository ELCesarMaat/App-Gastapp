<?xml version="1.0" encoding="utf-8"?>

<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Gastapp.Pages.Menu.SummaryPage"
             xmlns:vm="clr-namespace:Gastapp.ViewModels"
             xmlns:models="clr-namespace:Gastapp.Models"
             xmlns:system="clr-namespace:System;assembly=System.Runtime"
             x:DataType="vm:SummaryViewModel"
             xmlns:sf="clr-namespace:Syncfusion.Maui.Calendar;assembly=Syncfusion.Maui.Calendar">
    <CollectionView SelectionMode="None"
                    ItemsSource="{Binding Spendings, Mode=TwoWay}"
                    RemainingItemsThreshold="1"
                    RemainingItemsThresholdReached="ItemsView_OnRemainingItemsThresholdReached">


        <CollectionView.Header>
            <VerticalStackLayout>
                <FlexLayout JustifyContent="SpaceBetween">
                    <Label Margin="0" FontSize="20" >
                        <Label.FormattedText>
                            <FormattedString>
                                <Span Text="{Binding TodayDate, StringFormat='{0:dddd dd MMMM}'}" TextColor="White"/>
                                <!--<Span Text="{Binding User.IncomeType.IncomeTypeName, StringFormat=' - {0}'}" TextColor="White"/>-->
                            </FormattedString>
                        </Label.FormattedText>
                    </Label>
                    <Border HorizontalOptions="End" Padding="0" StrokeThickness="0">
                        <VerticalStackLayout Spacing="0" Margin="0">
                            <Label Text="Ver mas" TextColor="White" FontSize="12" Padding="0" />
                            <Label Text="&lt; &gt;" TextColor="White" HorizontalTextAlignment="Center" FontSize="20"
                                   Padding="-10" />
                        </VerticalStackLayout>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ToggleCalendarVisibleCommand}"/>
                        </Border.GestureRecognizers>
                    </Border>
                </FlexLayout>
                <!--<Label Text="{Binding TotalPeriodAmount, StringFormat='Total en el periodo: ${0}'}"
                       TextColor="White" Margin="0, 0, 0, 5"/>-->
                <sf:SfCalendar
                    IsVisible="{Binding IsCalendarVisible}"
                    BackgroundColor="White"
                    NavigationDirection="Horizontal"
                    HeightRequest="200"
                    x:Name="calendar"
                    SelectionMode="Range"
                    SelectionShape="Circle"
                    Background="Transparent"
                    TodayHighlightBrush="Green"
                    AllowViewNavigation="False"
                    SelectionChangedCommand="{Binding CalendarSelectionChangeCommand}"
                    View="Month">
                   
                    <sf:SfCalendar.MonthView>
                        <sf:CalendarMonthView NumberOfVisibleWeeks="5">
                        </sf:CalendarMonthView>
                    </sf:SfCalendar.MonthView>
                </sf:SfCalendar>
                <CollectionView SelectionMode="Single" FlowDirection="RightToLeft"
                                ItemsSource="{Binding Days}"
                                SelectedItem="{Binding SelectedDay}">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Horizontal" ItemSpacing="5" />
                    </CollectionView.ItemsLayout>

                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="system:DateTime">
                            <Border BackgroundColor="#00C6CD" Padding="4"
                                    HeightRequest="65" WidthRequest="65" StrokeThickness="0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="33" />
                                </Border.StrokeShape>
                                <VisualStateManager.VisualStateGroups>
                                    <VisualStateGroup Name="CommonStates">
                                        <VisualState Name="Normal">
                                            <VisualState.Setters>
                                                <Setter Property="Stroke"
                                                        Value="Transparent" />
                                                <Setter Property="StrokeThickness"
                                                        Value="0" />
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState Name="Selected">
                                            <VisualState.Setters>
                                                <Setter Property="Stroke"
                                                        Value="DarkGreen" />
                                                <Setter Property="StrokeThickness"
                                                        Value="3" />
                                                <Setter Property="BackgroundColor"
                                                        Value="#198E92" />
                                                <Setter Property="WidthRequest"
                                                        Value="68" />
                                                <Setter Property="HeightRequest"
                                                        Value="68" />
                                            </VisualState.Setters>
                                        </VisualState>
                                    </VisualStateGroup>
                                </VisualStateManager.VisualStateGroups>
                                <VerticalStackLayout HorizontalOptions="Center">
                                    <Label Text="{Binding ., StringFormat='{0:dddd}'}" TextColor="White" FontSize="10"
                                           Padding="0, 5, 0, -2" />

                                    <Label Text="{Binding ., StringFormat='{0:dd}'}" TextColor="White" FontSize="28"
                                           HorizontalTextAlignment="Center"
                                           Padding="0, -5, 0, 0" />

                                </VerticalStackLayout>

                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <Grid ColumnDefinitions="auto, *"
                      RowDefinitions="auto, auto, *"
                      Margin="0, 10">

                    <Label Text="GASTOS DEL DIA" Margin="0" FontSize="22"
                           TextColor="White" />

                    <Label Text="TOTAL GASTADO" Margin="0" FontSize="15"
                           Grid.Row="1"
                           TextColor="White" />

                    <Label Text="{Binding TotalAmount, StringFormat='${0:#,0.##}'}" Margin="0" LineBreakMode="TailTruncation" FontSize="45"
                           Grid.Row="0" Grid.Column="1" Grid.RowSpan="2"
                           HorizontalOptions="End"
                           VerticalOptions="Center"
                           HorizontalTextAlignment="Center"
                           TextColor="White" >
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ShowTotalToastCommand}"/>
                        </Label.GestureRecognizers>
                    </Label>

                    <VerticalStackLayout Grid.Row="2" Grid.ColumnSpan="2" Margin="0, 50"
                                         IsVisible="{Binding IsEmptyList}">
                        <Label Text="¡Todavia no tienes gastos registrados!"
                               FontSize="40" HorizontalTextAlignment="Center"
                               TextColor="#198E92" />
                        <Image Source="pig_sad" VerticalOptions="Start"/>
                    </VerticalStackLayout>

                </Grid>
                   
            </VerticalStackLayout>
        </CollectionView.Header>

        <!--<CollectionView.EmptyView>
            <VerticalStackLayout HorizontalOptions="Center">
                <Label Text="¡Todavia no tienes gastos registrados"
                       FontSize="40" HorizontalTextAlignment="Center"
                       TextColor="#198E92" />
                <Image Source="pig_sad" />
            </VerticalStackLayout>
        </CollectionView.EmptyView>-->

        <CollectionView.ItemsLayout>
            <LinearItemsLayout Orientation="Vertical" ItemSpacing="8" />
        </CollectionView.ItemsLayout>

        <CollectionView.ItemTemplate>
            <DataTemplate x:DataType="models:Spending">
                <SwipeView>
                    <SwipeView.RightItems>
                        <SwipeItems Mode="Reveal">
                            <SwipeItemView
                                BackgroundColor="Transparent"
                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:SummaryViewModel}},
                                          Path=DeleteSpendingCommand}"
                                CommandParameter="{Binding .}">
                                <Border HeightRequest="65" WidthRequest="65" Stroke="#FF7575"
                                        StrokeThickness="2"
                                        StrokeShape="RoundRectangle 33" BackgroundColor="#FF3535">
                                    <Image Source="icon_trash" Aspect="Center" />
                                </Border>
                            </SwipeItemView>

                        </SwipeItems>
                    </SwipeView.RightItems>

                    <Border BackgroundColor="#198E92" StrokeThickness="0"
                            StrokeShape="RoundRectangle 100">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer
                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:SummaryViewModel}},
                                          Path=SpendingClickedCommand}"
                                CommandParameter="{Binding .}" />

                        </Border.GestureRecognizers>

                        <FlexLayout JustifyContent="Start">
                            <Label HorizontalTextAlignment="Center"
                                   VerticalOptions="Center"
                                   FontSize="25" TextColor="White"
                                   Padding="5"
                                   Text="{Binding Amount, StringFormat='${0:#,0.##}'}" />
                            <Border BackgroundColor="#00C6CD" FlexLayout.Grow="1"
                                    StrokeThickness="0"
                                    Padding="8"
                                    StrokeShape="RoundRectangle 100">
                                <VerticalStackLayout Padding="20, 0, 0, 0">
                                    <Label Text="{Binding Title}"
                                           HorizontalTextAlignment="Center"
                                           FontSize="27"
                                           TextColor="White"
                                           Padding="-5" />
                                    <Label Text="{Binding Category.CategoryName}"
                                           TextColor="White"
                                           Padding="-5" />
                                    <Label Text="{Binding Date, StringFormat='{0:dd/MM/yyyy hh:mm tt}'}"
                                           TextColor="White"
                                           Padding="-5" />
                                </VerticalStackLayout>
                            </Border>
                        </FlexLayout>
                    </Border>

                </SwipeView>
            </DataTemplate>
        </CollectionView.ItemTemplate>

    </CollectionView>

</ContentView>