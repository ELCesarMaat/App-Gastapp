<?xml version="1.0" encoding="utf-8"?>

<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Gastapp.Pages.Menu.SummaryPage"
             x:Name="Root"
             xmlns:vm="clr-namespace:Gastapp.ViewModels"
             xmlns:models="clr-namespace:Gastapp.Models;assembly=Gastapp.Models"
             x:DataType="vm:SummaryViewModel"
             xmlns:sf="clr-namespace:Syncfusion.Maui.Calendar;assembly=Syncfusion.Maui.Calendar">
    <ContentView.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="0, 1">
            <GradientStop Color="{StaticResource SurfaceSecondary}" Offset="0.0" />
            <GradientStop Color="#E7F7F0" Offset="0.55" />
            <GradientStop Color="#FFFFFF" Offset="1.0" />
        </LinearGradientBrush>
    </ContentView.Background>

    <CollectionView SelectionMode="None"
                    ItemsSource="{Binding SpendingsGroup, Mode=TwoWay}"
                    IsGrouped="True">

        <CollectionView.Header>
            <VerticalStackLayout Padding="20,18,20,12" Spacing="16">
                <Border BackgroundColor="{StaticResource ButtonsGreen}" StrokeThickness="0" StrokeShape="RoundRectangle 28" Padding="20">
                    <VerticalStackLayout Spacing="14">
                        <Grid ColumnDefinitions="*,auto" ColumnSpacing="12">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="{Binding SelectedDateLabel}" TextColor="White" FontSize="28" />
                                <Label Text="{Binding SelectedDateCaption}" TextColor="White" FontSize="14" FontFamily="OpenSansRegular" Opacity="0.9" />
                            </VerticalStackLayout>

                            <Border Grid.Column="1" BackgroundColor="#1EFFFFFF" StrokeThickness="0" StrokeShape="RoundRectangle 16" Padding="12,10" VerticalOptions="Start">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding ToggleCalendarVisibleCommand}" />
                                </Border.GestureRecognizers>
                                <Label Text="{Binding CalendarToggleText}" TextColor="White" FontSize="13" FontFamily="OpenSansRegular" />
                            </Border>
                        </Grid>

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                            <Border Grid.Column="0" BackgroundColor="#1EFFFFFF" StrokeThickness="0" StrokeShape="RoundRectangle 18" Padding="14,12">
                                <VerticalStackLayout Spacing="2">
                                    <Label Text="Total del día" FontSize="12" TextColor="White" Opacity="0.78" FontFamily="OpenSansRegular" />
                                    <Label Text="{Binding TotalAmount, StringFormat='${0:N2}'}" TextColor="White" FontSize="24" />
                                </VerticalStackLayout>
                            </Border>

                            <Border Grid.Column="1" BackgroundColor="#1EFFFFFF" StrokeThickness="0" StrokeShape="RoundRectangle 18" Padding="14,12">
                                <VerticalStackLayout Spacing="2">
                                    <Label Text="Actividad" FontSize="12" TextColor="White" Opacity="0.78" FontFamily="OpenSansRegular" />
                                    <Label Text="{Binding SpendingCountText}" TextColor="White" FontSize="24" />
                                </VerticalStackLayout>
                            </Border>
                        </Grid>

                        <Border BackgroundColor="#14FFFFFF" StrokeThickness="0" StrokeShape="RoundRectangle 18" Padding="14,10">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="SelectFirstItem" Command="{Binding SetTodayDateCommand}" />
                            </Border.GestureRecognizers>
                            <Label Text="Ir a hoy" TextColor="White" HorizontalTextAlignment="Center" FontFamily="OpenSansRegular" />
                        </Border>
                    </VerticalStackLayout>
                </Border>

                <Border IsVisible="{Binding IsCalendarVisible}" BackgroundColor="White" Stroke="{StaticResource BorderSubtle}" StrokeShape="RoundRectangle 24" Padding="18">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="Explora por periodo" FontSize="22" TextColor="{StaticResource TextDarkColor}" />
                        <Label Text="{Binding PeriodSummaryText}" FontSize="14" TextColor="{StaticResource Gray500}" FontFamily="OpenSansRegular" />
                        <Label Text="{Binding TotalPeriodAmount, StringFormat='Total del periodo: ${0:N2}'}" FontSize="16" TextColor="{StaticResource ButtonsGreen}" />
                        <sf:SfCalendar
                            BackgroundColor="Transparent"
                            NavigationDirection="Horizontal"
                            HeightRequest="240"
                            x:Name="calendar"
                            SelectionMode="Range"
                            SelectionShape="Circle"
                            TodayHighlightBrush="{StaticResource ButtonsGreen}"
                            AllowViewNavigation="False"
                            SelectionChangedCommand="{Binding CalendarSelectionChangeCommand}"
                            View="Month">

                            <sf:SfCalendar.MonthView>
                                <sf:CalendarMonthView NumberOfVisibleWeeks="5" />
                            </sf:SfCalendar.MonthView>
                        </sf:SfCalendar>
                    </VerticalStackLayout>
                </Border>

                <CollectionView x:Name="DaysCollectionView"
                                SelectionMode="Single"
                                ItemsSource="{Binding Days}"
                                SelectedItem="{Binding SelectedDay}"
                                HeightRequest="92">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Horizontal" ItemSpacing="8" />
                    </CollectionView.ItemsLayout>

                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="vm:DayItem">
                            <Border BackgroundColor="White" Padding="6"
                                    HeightRequest="76" WidthRequest="76" Stroke="{StaticResource BorderSubtle}" StrokeThickness="1">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="20" />
                                </Border.StrokeShape>
                                <Border.Triggers>
                                    <DataTrigger TargetType="Border" Binding="{Binding HasSpendings}" Value="False">
                                        <Setter Property="Opacity" Value="0.4" />
                                        <Setter Property="BackgroundColor" Value="#F5F5F5" />
                                    </DataTrigger>
                                </Border.Triggers>
                                <VisualStateManager.VisualStateGroups>
                                    <VisualStateGroup Name="CommonStates">
                                        <VisualState Name="Normal">
                                            <VisualState.Setters>
                                                <Setter Property="Stroke"
                                                        Value="{StaticResource BorderSubtle}" />
                                                <Setter Property="BackgroundColor"
                                                        Value="White" />
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState Name="Selected">
                                            <VisualState.Setters>
                                                <Setter Property="Stroke"
                                                        Value="{StaticResource ButtonsGreen}" />
                                                <Setter Property="StrokeThickness"
                                                        Value="2" />
                                                <Setter Property="BackgroundColor"
                                                        Value="{StaticResource AccentSoft}" />
                                                <Setter Property="WidthRequest"
                                                        Value="80" />
                                                <Setter Property="HeightRequest"
                                                        Value="80" />
                                            </VisualState.Setters>
                                        </VisualState>
                                    </VisualStateGroup>
                                </VisualStateManager.VisualStateGroups>
                                <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="0"
                                      HorizontalOptions="Center" VerticalOptions="Center">
                                    <Label Grid.Row="0" Text="{Binding Date, StringFormat='{0:ddd}'}"
                                           TextColor="{StaticResource Gray500}" FontSize="12"
                                           HorizontalTextAlignment="Center" FontFamily="OpenSansRegular" />
                                    <Label Grid.Row="1" Text="{Binding Date, StringFormat='{0:dd}'}"
                                           TextColor="{StaticResource TextDarkColor}" FontSize="26"
                                           HorizontalTextAlignment="Center" />
                                    <BoxView Grid.Row="2" WidthRequest="6" HeightRequest="6"
                                             CornerRadius="3" BackgroundColor="{StaticResource ButtonsGreen}"
                                             HorizontalOptions="Center" IsVisible="{Binding HasSpendings}" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <VerticalStackLayout Spacing="8">
                    <Label Text="Tus movimientos" FontSize="22" TextColor="{StaticResource TextDarkColor}" />
                    <Label Text="{Binding PeriodSummaryText}" FontSize="14" TextColor="{StaticResource Gray500}" FontFamily="OpenSansRegular" />

                    <Border IsVisible="{Binding IsEmptyList}" BackgroundColor="White" Stroke="{StaticResource BorderSubtle}" StrokeShape="RoundRectangle 24" Padding="20">
                        <VerticalStackLayout Spacing="10">
                            <Label Text="Todavía no tienes gastos registrados para esta fecha." FontSize="22" TextColor="{StaticResource TextDarkColor}" HorizontalTextAlignment="Center" />
                            <Label Text="Cuando agregues un gasto, aquí verás el monto, la categoría y el acceso rápido al detalle." FontSize="14" TextColor="{StaticResource Gray500}" HorizontalTextAlignment="Center" FontFamily="OpenSansRegular" />
                            <Image Source="pig_sad" HeightRequest="140" Aspect="AspectFit" />
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>
            </VerticalStackLayout>
        </CollectionView.Header>

        <CollectionView.ItemsLayout>
            <LinearItemsLayout Orientation="Vertical" ItemSpacing="8" />
        </CollectionView.ItemsLayout>

        <CollectionView.GroupHeaderTemplate>
            <DataTemplate x:DataType="models:SpendingGroup">
                <Border Margin="20, 4, 20, 0" BackgroundColor="{StaticResource AccentSoft}" StrokeThickness="0" StrokeShape="RoundRectangle 18" Padding="14,10">
                    <Label FontSize="18" TextColor="{StaticResource TextDarkColor}">
                        <Label.FormattedText>
                            <FormattedString>
                                <Span Text="{Binding Name}" />
                                <Span Text="{Binding Amount, StringFormat=' · ${0:N2}'}" FontAttributes="Bold" />
                            </FormattedString>
                        </Label.FormattedText>
                    </Label>
                </Border>
            </DataTemplate>
        </CollectionView.GroupHeaderTemplate>
        <CollectionView.ItemTemplate>
            <DataTemplate x:DataType="models:Spending">
                <SwipeView Margin="20, 0">
                    <SwipeView.RightItems>
                        <SwipeItems Mode="Reveal">
                            <SwipeItemView
                                BackgroundColor="Transparent"
                                Command="{Binding Source={x:Reference Root}, Path=BindingContext.DeleteSpendingCommand}"
                                CommandParameter="{Binding .}">
                                <Border HeightRequest="72" WidthRequest="72" Stroke="#FFB0B0"
                                        StrokeThickness="2"
                                        StrokeShape="RoundRectangle 20" BackgroundColor="#F55656">
                                    <Image Source="icon_trash" Aspect="Center" />
                                </Border>
                            </SwipeItemView>

                        </SwipeItems>
                    </SwipeView.RightItems>

                    <Border BackgroundColor="White" Stroke="{StaticResource BorderSubtle}" StrokeShape="RoundRectangle 24" Padding="12">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer
                                Command="{Binding Source={x:Reference Root}, Path=BindingContext.SpendingClickedCommand}"
                                CommandParameter="{Binding .}" />

                        </Border.GestureRecognizers>

                        <Grid ColumnDefinitions="auto,*" ColumnSpacing="12">
                            <Border BackgroundColor="{StaticResource AccentSoft}" StrokeThickness="0" StrokeShape="RoundRectangle 16" Padding="12,10" VerticalOptions="Start">
                                <Label HorizontalTextAlignment="Center"
                                       VerticalOptions="Center"
                                       FontSize="18" TextColor="{StaticResource ButtonsGreen}"
                                       Text="{Binding Amount, StringFormat='${0:#,0.##}'}" />
                            </Border>

                            <VerticalStackLayout Grid.Column="1" Spacing="4">
                                <Label Text="{Binding Title}" FontSize="20" TextColor="{StaticResource TextDarkColor}" />
                                <Label Text="{Binding Category.CategoryName}" FontSize="14" TextColor="{StaticResource ButtonsGreen}" FontFamily="OpenSansRegular" />
                                <Label Text="{Binding Date, StringFormat='{0:hh:mm tt · dd/MM/yyyy}'}" FontSize="13" TextColor="{StaticResource Gray500}" FontFamily="OpenSansRegular" />
                                <Label Text="{Binding Description}" FontSize="14" TextColor="{StaticResource TextDarkColor}" FontFamily="OpenSansRegular" LineBreakMode="TailTruncation" MaxLines="2" />
                            </VerticalStackLayout>
                        </Grid>
                    </Border>

                </SwipeView>
            </DataTemplate>
        </CollectionView.ItemTemplate>

    </CollectionView>

</ContentView>