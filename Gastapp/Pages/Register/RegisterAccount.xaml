<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Gastapp.Pages.Register.RegisterAccount"
             xmlns:safe="clr-namespace:CommunityToolkit.Maui.Behaviors;assembly=CommunityToolkit.Maui"
             xmlns:buttons="clr-namespace:Gastapp.Controls"
             >
    <VerticalStackLayout
                Padding="30, 20"
                Spacing="10">
            <Label FontSize="30">
                <Label.FormattedText>
                    <FormattedString>
                        <Span Text="Crea tu cuenta" TextColor="{StaticResource TextGreenColor}" FontAttributes="Bold"/>
                        <Span Text=" con tu correo y contraseña" TextColor="{StaticResource TextDarkColor}" FontAttributes="Bold"/>

                    </FormattedString>
                </Label.FormattedText>
            </Label>

            <Label Text="Escribe tu correo electronico" Margin="0, 20" FontSize="16" FontAttributes="Bold"/>
            <Entry Keyboard="Email" ReturnType="Next"/>

            <Label Text="Confirma tu correo electronico" Margin="0, 20" FontSize="16" FontAttributes="Bold"/>
            <Entry Keyboard="Email" ReturnType="Next"/>

            <Label Text="Nombre de usuario" Margin="0, 20" FontSize="16" FontAttributes="Bold"/>
            <Entry Keyboard="Text" ReturnType="Done"/>

            </VerticalStackLayout>

       

</ContentView>