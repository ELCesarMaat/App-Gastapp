<?xml version="1.0" encoding="utf-8"?>

<bs:BottomSheet xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                xmlns:vm="clr-namespace:Gastapp.ViewModels"
                x:DataType="vm:NewSpendingViewModel"
                x:Name="Root"
                x:Class="Gastapp.BottomSheets.NewSpendingBottomSheet"
                xmlns:bs="https://schemas.the49.com/dotnet/2023/maui"
                BackgroundColor="Transparent"
                CornerRadius="0"
                HasHandle="False"
                IsCancelable="False"
                HasBackdrop="True">
    <bs:BottomSheet.Detents>
        <bs:RatioDetent Ratio=".9"/>
        <bs:RatioDetent Ratio=".75"/>
    </bs:BottomSheet.Detents>

    <ScrollView>
        <Border StrokeThickness="0" StrokeShape="RoundRectangle 24, 24, 0, 0"
                BackgroundColor="{StaticResource SurfacePrimary}">
            <VerticalStackLayout Spacing="0" Padding="0,0,0,36">
                <!-- Header: Cancelar | drag-handle | Guardar -->
                <Grid ColumnDefinitions="auto, *, auto" Padding="12,14,12,12">
                    <Label Grid.Column="0"
                           Text="Cancelar"
                           TextColor="{StaticResource ErrorColor}"
                           FontSize="15"
                           FontAttributes="Bold"
                           Padding="8,6"
                           VerticalOptions="Center">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="CloseBottomSheet"/>
                        </Label.GestureRecognizers>
                    </Label>
                    <Border Grid.Column="1"
                            HeightRequest="4" WidthRequest="40"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 2"
                            BackgroundColor="{StaticResource Gray300}"
                            HorizontalOptions="Center" VerticalOptions="Center"/>
                    <Label Grid.Column="2"
                           Text="Guardar"
                           TextColor="{StaticResource SuccessColor}"
                           FontSize="15"
                           FontAttributes="Bold"
                           Padding="8,6"
                           VerticalOptions="Center">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="SaveSpending"/>
                        </Label.GestureRecognizers>
                    </Label>
                </Grid>


                <!-- Title -->
                  <Label Text="{Binding BottomSheetTitle}"
                       HorizontalTextAlignment="Center"
                       FontSize="20"
                       FontFamily="BalooRegular"
                       TextColor="{StaticResource TextDarkColor}"
                       Margin="0,4,0,20"/>

                <!-- Amount -->
                <Border StrokeShape="RoundRectangle 16"
                        StrokeThickness="1.5"
                        Stroke="{StaticResource BorderSubtle}"
                        BackgroundColor="{StaticResource SurfaceSecondary}"
                        Margin="16,0" Padding="16,10">
                    <VerticalStackLayout Spacing="0">
                        <Label Text="CANTIDAD"
                               FontSize="11"
                               TextColor="{StaticResource NavInactiveText}"
                               FontAttributes="Bold"
                               HorizontalTextAlignment="Center"
                               Margin="0,0,0,2"/>
                        <Entry Placeholder="0.00"
                               HorizontalTextAlignment="Center"
                               Keyboard="Numeric"
                               ReturnType="Next"
                               FontSize="32"
                               FontFamily="BalooRegular"
                               TextColor="{StaticResource TextDarkColor}"
                               MaxLength="10"
                               Text="{Binding Amount}"
                               HeightRequest="60"/>
                    </VerticalStackLayout>
                </Border>

                <!-- Divider -->
                <BoxView HeightRequest="1" BackgroundColor="{StaticResource BorderSubtle}"
                         Margin="16,20"/>

                <!-- Category -->

                <Label Text="Categorías"
                       FontSize="13" FontAttributes="Bold"
                       TextColor="{StaticResource TextDarkColor}"
                       Margin="20,0,20,8"/>

                <!-- Picker para seleccionar categoría -->
                <Border StrokeShape="RoundRectangle 12"
                        StrokeThickness="1.5"
                        Stroke="{StaticResource BorderSubtle}"
                        BackgroundColor="{StaticResource SurfaceSecondary}"
                        Margin="16,0" Padding="14,0">
                    <Picker ItemsSource="{Binding Categories}"
                            ItemDisplayBinding="{Binding CategoryName}"
                            SelectedItem="{Binding SelectedCategory}"
                            HeightRequest="48"/>
                </Border>

                    <Button Text="Eliminar categoría"
                        HorizontalOptions="End"
                        Padding="12,0"
                        FontSize="12"
                        HeightRequest="32"
                        Margin="16,10,16,0"
                        BackgroundColor="{StaticResource ErrorColor}"
                        TextColor="White"
                        Command="{Binding DeleteCategoryCommand}"
                        CommandParameter="{Binding Source={x:Reference Name=Root}, Path=BindingContext.SelectedCategory}"
                        IsVisible="{Binding CanDeleteSelectedCategory}"/>

                <Button Text="+ Nueva categor&#237;a"
                        HorizontalOptions="End"
                        Padding="12,0"
                        FontSize="12"
                        HeightRequest="32"
                        Margin="16,10,16,0"
                        BackgroundColor="{StaticResource AccentSoft}"
                        TextColor="{StaticResource TextGreenColor}"
                        Command="{Binding ShowNewCategoryCommand}"/>

                <!-- New category panel -->
                <Border StrokeShape="RoundRectangle 12"
                        Padding="16" Margin="16,10,16,0"
                        BackgroundColor="{StaticResource SurfaceSecondary}"
                        StrokeThickness="0"
                        IsVisible="{Binding ShowNewCategoryField}">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Nueva categor&#237;a"
                               FontSize="13" FontAttributes="Bold"
                               TextColor="{StaticResource TextDarkColor}"/>
                        <Border StrokeShape="RoundRectangle 10"
                                StrokeThickness="1.5"
                                Stroke="{StaticResource BorderSubtle}"
                                BackgroundColor="{StaticResource SurfacePrimary}"
                                Padding="12,0">
                            <Entry Keyboard="Text" ReturnType="Done"
                                   HeightRequest="44" MaxLength="50"
                                   Text="{Binding NewCategoryName}"
                                   Placeholder="Nombre de la categor&#237;a"/>
                        </Border>
                        <Button Text="Guardar categor&#237;a"
                                HorizontalOptions="Fill"
                                HeightRequest="40"
                                Command="{Binding SaveNewCategoryCommand}"/>
                    </VerticalStackLayout>
                </Border>

                <!-- Divider -->
                <BoxView HeightRequest="1" BackgroundColor="{StaticResource BorderSubtle}"
                         Margin="16,18"/>

                <!-- Title field -->
                <Label Text="T&#237;tulo"
                       FontSize="13" FontAttributes="Bold"
                       TextColor="{StaticResource TextDarkColor}"
                       Margin="20,0,20,8"/>
                <Border StrokeShape="RoundRectangle 12"
                        StrokeThickness="1.5"
                        Stroke="{StaticResource BorderSubtle}"
                        BackgroundColor="{StaticResource SurfaceSecondary}"
                        Margin="16,0" Padding="14,0">
                    <Entry HorizontalTextAlignment="Start"
                           Keyboard="Text" ReturnType="Next"
                           HeightRequest="48" MaxLength="50"
                           Text="{Binding Title}"
                           Placeholder="Ej. Supermercado, caf&#233;..."/>
                </Border>

                <!-- Description field -->
                <Label Text="Descripci&#243;n (opcional)"
                       FontSize="13" FontAttributes="Bold"
                       TextColor="{StaticResource TextDarkColor}"
                       Margin="20,18,20,8"/>
                <Border StrokeShape="RoundRectangle 12"
                        StrokeThickness="1.5"
                        Stroke="{StaticResource BorderSubtle}"
                        BackgroundColor="{StaticResource SurfaceSecondary}"
                        Margin="16,0" Padding="14,0">
                    <Entry HorizontalTextAlignment="Start"
                           Keyboard="Text" ReturnType="Done"
                           HeightRequest="48" MaxLength="100"
                           Text="{Binding Description}"
                           Placeholder="Agrega una nota..."/>
                </Border>

                <!-- Date section -->
                <VerticalStackLayout IsVisible="{Binding CanChangeDate}">
                    <BoxView HeightRequest="1" BackgroundColor="{StaticResource BorderSubtle}"
                             Margin="16,18"/>
                    <Label Text="Fecha del gasto"
                           FontSize="13" FontAttributes="Bold"
                           TextColor="{StaticResource TextDarkColor}"
                           Margin="20,0,20,12"/>
                    <Border StrokeShape="RoundRectangle 12"
                            StrokeThickness="0"
                            BackgroundColor="{StaticResource SurfaceSecondary}"
                            Margin="16,0" Padding="16,14">
                        <Grid ColumnDefinitions="auto, *, auto" RowDefinitions="auto, auto"
                              ColumnSpacing="10" RowSpacing="4">
                            <CheckBox Grid.Column="0" Grid.RowSpan="2"
                                      IsChecked="{Binding UseSelectedDate}"
                                      Color="{StaticResource ButtonsGreen}"
                                      VerticalOptions="Center"/>
                            <Label Grid.Column="1" Grid.Row="0"
                                   Text="Guardar en el d&#237;a seleccionado"
                                   FontSize="14" TextColor="{StaticResource TextDarkColor}"
                                   VerticalOptions="End"/>
                            <Label Grid.Column="1" Grid.Row="1"
                                   Text="{Binding MenuSelectedDate, StringFormat='{0:dddd dd MMMM}'}"
                                   FontSize="12" TextColor="{StaticResource NavInactiveText}"
                                   VerticalOptions="Start"
                                   IsVisible="{Binding UseSelectedDate}"/>
                            <TimePicker Grid.Column="2" Grid.RowSpan="2"
                                        Time="{Binding SelectedTime}"
                                        VerticalOptions="Center"
                                        IsVisible="{Binding UseSelectedDate}"/>
                        </Grid>
                    </Border>
                </VerticalStackLayout>

            </VerticalStackLayout>
        </Border>
    </ScrollView>
</bs:BottomSheet>
