<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Gastapp.Pages.Menu.SpendingDetailPage"
             Shell.NavBarIsVisible="False"
             xmlns:vm="clr-namespace:Gastapp.ViewModels"
             x:DataType="vm:DetailViewModel"
             HideSoftInputOnTapped="True">

    <ContentPage.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="0, 1">
                     <GradientStop Color="{StaticResource SurfaceSecondary}" Offset="0.0" />
                     <GradientStop Color="#E8F8F2" Offset="0.55" />
                     <GradientStop Color="#FFFFFF" Offset="1.0" />
        </LinearGradientBrush>
    </ContentPage.Background>

       <Grid RowDefinitions="auto,*">
              <VerticalStackLayout Grid.Row="0" Padding="20,18,20,12" Spacing="16">
                     <Grid ColumnDefinitions="auto,*,auto" ColumnSpacing="14">
                            <Border HeightRequest="44" WidthRequest="44" BackgroundColor="White" Stroke="{StaticResource BorderSubtle}" StrokeShape="RoundRectangle 22">
                                   <ImageButton Source="backarrow" BackgroundColor="Transparent" WidthRequest="44" HeightRequest="44" Command="{Binding GoBackCommand}" />
                            </Border>

                            <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                   <Label Text="Detalle del gasto" FontSize="28" TextColor="{StaticResource TextDarkColor}" />
                                   <Label Text="{Binding HeaderSubtitle}" FontSize="14" TextColor="{StaticResource Gray500}" FontFamily="OpenSansRegular" />
                            </VerticalStackLayout>

                            <Button Grid.Column="2"
                                    Text="Editar"
                                    FontSize="14"
                                    Padding="10,0"
                                    HeightRequest="36"
                                    VerticalOptions="Center"
                                    Command="{Binding EditSpendingCommand}" />
                     </Grid>

                     <Border BackgroundColor="{StaticResource ButtonsGreen}" StrokeThickness="0" StrokeShape="RoundRectangle 28" Padding="22">
                            <VerticalStackLayout Spacing="6">
                                   <Label Text="{Binding Spending.Title}" HorizontalTextAlignment="Center" TextColor="White" FontSize="28" />
                                   <Label Text="{Binding AmountText}" HorizontalTextAlignment="Center" TextColor="White" FontSize="36" />
                                   <Label Text="{Binding LongDateText}" HorizontalTextAlignment="Center" TextColor="White" FontSize="15" FontFamily="OpenSansRegular" Opacity="0.9" />
                            </VerticalStackLayout>
                     </Border>
              </VerticalStackLayout>

              <ScrollView Grid.Row="1">
                     <VerticalStackLayout Padding="20,0,20,28" Spacing="16">
                            <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                                   <Border Grid.Column="0" BackgroundColor="White" Stroke="{StaticResource BorderSubtle}" StrokeShape="RoundRectangle 22" Padding="16">
                                          <VerticalStackLayout Spacing="6">
                                                 <Label Text="Categoría" FontSize="13" TextColor="{StaticResource Gray500}" FontFamily="OpenSansRegular" />
                                                 <Label Text="{Binding CategoryText}" FontSize="18" TextColor="{StaticResource TextDarkColor}" />
                                          </VerticalStackLayout>
                                   </Border>

                                   <Border Grid.Column="1" BackgroundColor="White" Stroke="{StaticResource BorderSubtle}" StrokeShape="RoundRectangle 22" Padding="16">
                                          <VerticalStackLayout Spacing="6">
                                                 <Label Text="Hora de registro" FontSize="13" TextColor="{StaticResource Gray500}" FontFamily="OpenSansRegular" />
                                                 <Label Text="{Binding TimeText}" FontSize="18" TextColor="{StaticResource TextDarkColor}" />
                                          </VerticalStackLayout>
                                   </Border>
                            </Grid>

                            <Border BackgroundColor="White" Stroke="{StaticResource BorderSubtle}" StrokeShape="RoundRectangle 24" Padding="18">
                                   <VerticalStackLayout Spacing="10">
                                          <Label Text="Descripción" FontSize="22" TextColor="{StaticResource TextDarkColor}" />
                                          <Label Text="{Binding DescriptionText}" FontSize="15" TextColor="{StaticResource TextDarkColor}" FontFamily="OpenSansRegular" />
                                   </VerticalStackLayout>
                            </Border>

                            <Border BackgroundColor="{StaticResource AccentSoft}" StrokeThickness="0" StrokeShape="RoundRectangle 24" Padding="18">
                                   <VerticalStackLayout Spacing="10">
                                          <Label Text="Datos del movimiento" FontSize="22" TextColor="{StaticResource TextDarkColor}" />

                                          <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                                                 <VerticalStackLayout Grid.Column="0" Spacing="2">
                                                        <Label Text="Importe" FontSize="13" TextColor="{StaticResource Gray500}" FontFamily="OpenSansRegular" />
                                                        <Label Text="{Binding AmountText}" FontSize="18" TextColor="{StaticResource TextDarkColor}" />
                                                 </VerticalStackLayout>

                                                 <VerticalStackLayout Grid.Column="1" Spacing="2">
                                                        <Label Text="Fecha" FontSize="13" TextColor="{StaticResource Gray500}" FontFamily="OpenSansRegular" />
                                                        <Label Text="{Binding Spending.Date, StringFormat='{0:dd/MM/yyyy}'}" FontSize="18" TextColor="{StaticResource TextDarkColor}" />
                                                 </VerticalStackLayout>
                                          </Grid>
                                   </VerticalStackLayout>
                            </Border>
                     </VerticalStackLayout>
              </ScrollView>
    </Grid>
</ContentPage>