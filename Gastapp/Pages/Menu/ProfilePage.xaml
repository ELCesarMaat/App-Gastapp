<?xml version="1.0" encoding="utf-8"?>

<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Gastapp.Pages.Menu.ProfilePage"
             xmlns:vm="clr-namespace:Gastapp.ViewModels"
             x:DataType="vm:ProfileViewModel"
             BackgroundColor="White">
    <ContentView.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="{StaticResource SurfaceSecondary}" Offset="0.0" />
            <GradientStop Color="White" Offset="1.0" />
        </LinearGradientBrush>
    </ContentView.Background>
    <ScrollView>
        <VerticalStackLayout Padding="20, 18, 20, 28" Spacing="18">
            <Border BackgroundColor="{StaticResource ButtonsGreen}" StrokeThickness="0" StrokeShape="RoundRectangle 28" Padding="20">
                <VerticalStackLayout Spacing="14">
                    <Grid ColumnDefinitions="auto,*" ColumnSpacing="14">
                        <Border WidthRequest="72" HeightRequest="72" BackgroundColor="#1EFFFFFF" StrokeThickness="0" StrokeShape="RoundRectangle 36">
                            <Label Text="{Binding Initials}" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" TextColor="White" FontSize="24" />
                        </Border>

                        <VerticalStackLayout Grid.Column="1" Spacing="4" VerticalOptions="Center">
                            <Label Text="Perfil" FontSize="13" TextColor="White" Opacity="0.8" FontFamily="OpenSansRegular" />
                            <Label Text="{Binding DisplayName}" FontSize="28" TextColor="White" />
                            <Label Text="{Binding ProfileSubtitle}" FontSize="14" TextColor="White" Opacity="0.92" FontFamily="OpenSansRegular" />
                        </VerticalStackLayout>
                    </Grid>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                        <Border Grid.Column="0" BackgroundColor="#1EFFFFFF" StrokeThickness="0" StrokeShape="RoundRectangle 18" Padding="14,12">
                            <VerticalStackLayout Spacing="2">
                                <Label Text="Ingreso base" FontSize="12" TextColor="White" Opacity="0.78" FontFamily="OpenSansRegular" />
                                <Label Text="{Binding IncomeSummary}" FontSize="18" TextColor="White" />
                            </VerticalStackLayout>
                        </Border>

                        <Border Grid.Column="1" BackgroundColor="#1EFFFFFF" StrokeThickness="0" StrokeShape="RoundRectangle 18" Padding="14,12">
                            <VerticalStackLayout Spacing="2">
                                <Label Text="Objetivo" FontSize="12" TextColor="White" Opacity="0.78" FontFamily="OpenSansRegular" />
                                <Label Text="{Binding SaveGoalSummary}" FontSize="18" TextColor="White" />
                            </VerticalStackLayout>
                        </Border>
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <Border BackgroundColor="White" Stroke="{StaticResource BorderSubtle}" StrokeShape="RoundRectangle 24" Padding="18">
                <VerticalStackLayout Spacing="14">
                    <Label Text="Tu cuenta" FontSize="22" TextColor="{StaticResource TextDarkColor}" />
                    <Label Text="Información principal para mantener tu perfil financiero claro y actualizado." FontFamily="OpenSansRegular" TextColor="{StaticResource Gray500}" />

                    <Grid ColumnDefinitions="auto,*" ColumnSpacing="12">
                        <Image Source="profile_icon.svg" WidthRequest="22" HeightRequest="22" VerticalOptions="Center" />
                        <VerticalStackLayout Grid.Column="1" Spacing="2">
                            <Label Text="Correo" FontSize="13" TextColor="{StaticResource Gray500}" FontFamily="OpenSansRegular" />
                            <Label Text="{Binding EmailSummary}" FontSize="16" TextColor="{StaticResource TextDarkColor}" />
                        </VerticalStackLayout>
                    </Grid>

                    <Grid ColumnDefinitions="auto,*" ColumnSpacing="12">
                        <Image Source="saves_icon.svg" WidthRequest="22" HeightRequest="22" VerticalOptions="Center" />
                        <VerticalStackLayout Grid.Column="1" Spacing="2">
                            <Label Text="Frecuencia de pago" FontSize="13" TextColor="{StaticResource Gray500}" FontFamily="OpenSansRegular" />
                            <Label Text="{Binding PayScheduleSummary}" FontSize="16" TextColor="{StaticResource TextDarkColor}" />
                        </VerticalStackLayout>
                    </Grid>

                    <Grid ColumnDefinitions="auto,*" ColumnSpacing="12">
                        <Image Source="about_icon.svg" WidthRequest="22" HeightRequest="22" VerticalOptions="Center" />
                        <VerticalStackLayout Grid.Column="1" Spacing="2">
                            <Label Text="Fecha de nacimiento" FontSize="13" TextColor="{StaticResource Gray500}" FontFamily="OpenSansRegular" />
                            <Label Text="{Binding BirthDateSummary}" FontSize="16" TextColor="{StaticResource TextDarkColor}" />
                        </VerticalStackLayout>
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <Border BackgroundColor="White" Stroke="{StaticResource BorderSubtle}" StrokeShape="RoundRectangle 24" Padding="18">
                <VerticalStackLayout Spacing="14">
                    <Label Text="Frecuencia de pago" FontSize="22" TextColor="{StaticResource TextDarkColor}" />
                    <Label Text="Ajusta cómo recibes ingresos." FontFamily="OpenSansRegular" TextColor="{StaticResource Gray500}" />

                    <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
                        <Border Grid.Column="0" BackgroundColor="#F0F3F2" StrokeThickness="0" StrokeShape="RoundRectangle 14" Padding="0" HeightRequest="42">
                            <Border.Triggers>
                                <DataTrigger TargetType="Border" Binding="{Binding IsWeekSelected}" Value="True">
                                    <Setter Property="BackgroundColor" Value="{StaticResource ButtonsGreen}" />
                                </DataTrigger>
                            </Border.Triggers>
                            <Label Text="Semanal" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" FontSize="14" TextColor="{StaticResource Gray500}">
                                <Label.Triggers>
                                    <DataTrigger TargetType="Label" Binding="{Binding IsWeekSelected}" Value="True">
                                        <Setter Property="TextColor" Value="White" />
                                    </DataTrigger>
                                </Label.Triggers>
                            </Label>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SelectFrequencyCommand}" CommandParameter="week" />
                            </Border.GestureRecognizers>
                        </Border>

                        <Border Grid.Column="1" BackgroundColor="#F0F3F2" StrokeThickness="0" StrokeShape="RoundRectangle 14" Padding="0" HeightRequest="42">
                            <Border.Triggers>
                                <DataTrigger TargetType="Border" Binding="{Binding IsBiWeekSelected}" Value="True">
                                    <Setter Property="BackgroundColor" Value="{StaticResource ButtonsGreen}" />
                                </DataTrigger>
                            </Border.Triggers>
                            <Label Text="Quincenal" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" FontSize="14" TextColor="{StaticResource Gray500}">
                                <Label.Triggers>
                                    <DataTrigger TargetType="Label" Binding="{Binding IsBiWeekSelected}" Value="True">
                                        <Setter Property="TextColor" Value="White" />
                                    </DataTrigger>
                                </Label.Triggers>
                            </Label>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SelectFrequencyCommand}" CommandParameter="biweek" />
                            </Border.GestureRecognizers>
                        </Border>

                        <Border Grid.Column="2" BackgroundColor="#F0F3F2" StrokeThickness="0" StrokeShape="RoundRectangle 14" Padding="0" HeightRequest="42">
                            <Border.Triggers>
                                <DataTrigger TargetType="Border" Binding="{Binding IsMonthSelected}" Value="True">
                                    <Setter Property="BackgroundColor" Value="{StaticResource ButtonsGreen}" />
                                </DataTrigger>
                            </Border.Triggers>
                            <Label Text="Mensual" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" FontSize="14" TextColor="{StaticResource Gray500}">
                                <Label.Triggers>
                                    <DataTrigger TargetType="Label" Binding="{Binding IsMonthSelected}" Value="True">
                                        <Setter Property="TextColor" Value="White" />
                                    </DataTrigger>
                                </Label.Triggers>
                            </Label>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SelectFrequencyCommand}" CommandParameter="month" />
                            </Border.GestureRecognizers>
                        </Border>
                    </Grid>

                    <Label Text="{Binding PayScheduleSummary}" FontFamily="OpenSansRegular" FontSize="13" TextColor="{StaticResource TextDarkColor}" />

                    <Border IsVisible="{Binding IsWeekSelected}" BackgroundColor="#F5F8F7" StrokeThickness="0" StrokeShape="RoundRectangle 14" Padding="14,0" HeightRequest="48">
                        <Picker Title="Selecciona tu día de pago"
                                ItemsSource="{Binding ListForWeek}"
                                ItemDisplayBinding="{Binding DayName}"
                                SelectedItem="{Binding SelectedWeekDay}" />
                    </Border>

                    <Grid IsVisible="{Binding IsBiWeekSelected}" ColumnDefinitions="*,*" ColumnSpacing="10">
                        <Border Grid.Column="0" BackgroundColor="#F5F8F7" StrokeThickness="0" StrokeShape="RoundRectangle 14" Padding="14,0" HeightRequest="48">
                            <Picker Title="Primer día"
                                    ItemsSource="{Binding FirstDayList}" SelectedItem="{Binding SelectedFirstDay}" />
                        </Border>
                        <Border Grid.Column="1" BackgroundColor="#F5F8F7" StrokeThickness="0" StrokeShape="RoundRectangle 14" Padding="14,0" HeightRequest="48">
                            <Picker Title="Segundo día"
                                    ItemsSource="{Binding SecondDayList}" SelectedItem="{Binding SelectedSecondDay}" />
                        </Border>
                    </Grid>

                    <Border IsVisible="{Binding IsMonthSelected}" BackgroundColor="#F5F8F7" StrokeThickness="0" StrokeShape="RoundRectangle 14" Padding="14,0" HeightRequest="48">
                        <Picker Title="Día de pago mensual"
                                ItemsSource="{Binding FirstDayList}"
                                SelectedItem="{Binding SelectedFirstDay}" />
                    </Border>
                </VerticalStackLayout>
            </Border>

            <Border BackgroundColor="White" Stroke="{StaticResource BorderSubtle}" StrokeShape="RoundRectangle 24" Padding="18">
                <VerticalStackLayout Spacing="14">
                    <Label Text="Objetivo de ahorro" FontSize="22" TextColor="{StaticResource TextDarkColor}" />
                    <Label Text="Elige cómo definir tu meta de ahorro." FontFamily="OpenSansRegular" TextColor="{StaticResource Gray500}" />

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                        <Border Grid.Column="0" BackgroundColor="#F0F3F2" StrokeThickness="0" StrokeShape="RoundRectangle 14" Padding="0" HeightRequest="42">
                            <Border.Triggers>
                                <DataTrigger TargetType="Border" Binding="{Binding IsSavingByPercent}" Value="True">
                                    <Setter Property="BackgroundColor" Value="{StaticResource ButtonsGreen}" />
                                </DataTrigger>
                            </Border.Triggers>
                            <Label Text="Porcentaje" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" FontSize="14" TextColor="{StaticResource Gray500}">
                                <Label.Triggers>
                                    <DataTrigger TargetType="Label" Binding="{Binding IsSavingByPercent}" Value="True">
                                        <Setter Property="TextColor" Value="White" />
                                    </DataTrigger>
                                </Label.Triggers>
                            </Label>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SelectSavingsModeCommand}" CommandParameter="percent" />
                            </Border.GestureRecognizers>
                        </Border>

                        <Border Grid.Column="1" BackgroundColor="#F0F3F2" StrokeThickness="0" StrokeShape="RoundRectangle 14" Padding="0" HeightRequest="42">
                            <Border.Triggers>
                                <DataTrigger TargetType="Border" Binding="{Binding IsSavingByAmount}" Value="True">
                                    <Setter Property="BackgroundColor" Value="{StaticResource ButtonsGreen}" />
                                </DataTrigger>
                            </Border.Triggers>
                            <Label Text="Cantidad fija" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" FontSize="14" TextColor="{StaticResource Gray500}">
                                <Label.Triggers>
                                    <DataTrigger TargetType="Label" Binding="{Binding IsSavingByAmount}" Value="True">
                                        <Setter Property="TextColor" Value="White" />
                                    </DataTrigger>
                                </Label.Triggers>
                            </Label>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SelectSavingsModeCommand}" CommandParameter="amount" />
                            </Border.GestureRecognizers>
                        </Border>
                    </Grid>

                    <VerticalStackLayout Spacing="6">
                        <Label Text="Sueldo por periodo" FontSize="14" TextColor="{StaticResource Gray500}" FontFamily="OpenSansRegular" />
                        <Border BackgroundColor="#F5F8F7" StrokeThickness="0" StrokeShape="RoundRectangle 14" Padding="14,0" HeightRequest="48">
                            <Grid ColumnDefinitions="auto,*" ColumnSpacing="8">
                                <Label Text="$" VerticalTextAlignment="Center" TextColor="{StaticResource Gray400}" FontSize="16" />
                                <Entry Grid.Column="1" Keyboard="Numeric" ReturnType="Next" Placeholder="0"
                                       Text="{Binding SalaryInput}" BackgroundColor="Transparent" FontSize="16" />
                            </Grid>
                        </Border>
                    </VerticalStackLayout>

                    <VerticalStackLayout IsVisible="{Binding IsSavingByPercent}" Spacing="6">
                        <Label Text="Porcentaje de ahorro" FontSize="14" TextColor="{StaticResource Gray500}" FontFamily="OpenSansRegular" />
                        <Border BackgroundColor="#F5F8F7" StrokeThickness="0" StrokeShape="RoundRectangle 14" Padding="14,0" HeightRequest="48">
                            <Grid ColumnDefinitions="auto,*" ColumnSpacing="8">
                                <Label Text="%" VerticalTextAlignment="Center" TextColor="{StaticResource Gray400}" FontSize="16" />
                                <Entry Grid.Column="1" Keyboard="Numeric" ReturnType="Done" Placeholder="10"
                                       Text="{Binding PercentSaveInput}" BackgroundColor="Transparent" FontSize="16" />
                            </Grid>
                        </Border>
                    </VerticalStackLayout>

                    <VerticalStackLayout IsVisible="{Binding IsSavingByAmount}" Spacing="6">
                        <Label Text="Cantidad a ahorrar" FontSize="14" TextColor="{StaticResource Gray500}" FontFamily="OpenSansRegular" />
                        <Border BackgroundColor="#F5F8F7" StrokeThickness="0" StrokeShape="RoundRectangle 14" Padding="14,0" HeightRequest="48">
                            <Grid ColumnDefinitions="auto,*" ColumnSpacing="8">
                                <Label Text="$" VerticalTextAlignment="Center" TextColor="{StaticResource Gray400}" FontSize="16" />
                                <Entry Grid.Column="1" Keyboard="Numeric" ReturnType="Done" Placeholder="0"
                                       Text="{Binding FixedAmountInput}" BackgroundColor="Transparent" FontSize="16" />
                            </Grid>
                        </Border>
                        <Label IsVisible="{Binding IsSavingByAmount}" Text="{Binding ComputedPercentInfo}" FontSize="12" FontFamily="OpenSansRegular" TextColor="{StaticResource TextGreenColor}" Margin="4,0,0,0" />
                    </VerticalStackLayout>

                    <Border BackgroundColor="{StaticResource AccentSoft}" StrokeThickness="0" StrokeShape="RoundRectangle 18" Padding="14,12">
                        <VerticalStackLayout Spacing="6">
                            <Label Text="{Binding EstimatedSavingsText}" FontSize="18" TextColor="{StaticResource ButtonsGreen}" />
                            <Label Text="{Binding EstimatedSpendableText}" FontFamily="OpenSansRegular" TextColor="{StaticResource TextDarkColor}" />
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>
            </Border>

            <Border BackgroundColor="White" Stroke="{StaticResource BorderSubtle}" StrokeShape="RoundRectangle 24" Padding="18">
                <VerticalStackLayout Spacing="14">
                    <Label Text="Sincronización en la nube" FontSize="22" TextColor="{StaticResource TextDarkColor}" />
                    <Label Text="Aquí puedes ver si toda tu información local ya quedó respaldada en la nube o si aún faltan cambios por subir." FontFamily="OpenSansRegular" TextColor="{StaticResource Gray500}" />

                    <Border BackgroundColor="{Binding CloudSyncCardBackground}"
                            Stroke="{Binding CloudSyncCardStroke}"
                            StrokeShape="RoundRectangle 20"
                            Padding="16">
                        <VerticalStackLayout Spacing="12">
                            <Grid ColumnDefinitions="auto,*,auto" ColumnSpacing="12">
                                <Image Source="backup_icon.svg" WidthRequest="24" HeightRequest="24" VerticalOptions="Start" />
                                <VerticalStackLayout Grid.Column="1" Spacing="4">
                                    <Label Text="{Binding CloudSyncTitle}" FontSize="16" TextColor="{StaticResource TextDarkColor}" />
                                    <Label Text="{Binding CloudSyncMessage}" FontSize="13" TextColor="{StaticResource Gray500}" FontFamily="OpenSansRegular" />
                                </VerticalStackLayout>
                                <Border Grid.Column="2"
                                        BackgroundColor="{Binding CloudSyncBadgeBackground}"
                                        StrokeThickness="0"
                                        StrokeShape="RoundRectangle 12"
                                        Padding="10,6"
                                        VerticalOptions="Start">
                                    <Label Text="{Binding CloudSyncBadgeText}" FontSize="12" TextColor="{Binding CloudSyncBadgeTextColor}" />
                                </Border>
                            </Grid>

                            <Border StrokeThickness="0"
                                    StrokeShape="RoundRectangle 14"
                                    BackgroundColor="#FFFFFFFF"
                                    Padding="12,10">
                                <Label Text="{Binding CloudSyncDetail}"
                                       FontSize="13"
                                       FontFamily="OpenSansRegular"
                                       TextColor="{StaticResource TextDarkColor}" />
                            </Border>
                        </VerticalStackLayout>
                    </Border>

                    <Grid ColumnDefinitions="auto,*,auto" ColumnSpacing="12">
                        <Image Source="contact_icon.svg" WidthRequest="22" HeightRequest="22" VerticalOptions="Center" />
                        <VerticalStackLayout Grid.Column="1" Spacing="2">
                            <Label Text="Soporte y contacto" FontSize="16" TextColor="{StaticResource TextDarkColor}" />
                            <Label Text="Centraliza ayuda, preguntas frecuentes y contacto desde un solo lugar." FontSize="13" TextColor="{StaticResource Gray500}" FontFamily="OpenSansRegular" />
                        </VerticalStackLayout>
                        <Border Grid.Column="2" BackgroundColor="{StaticResource AccentSoft}" StrokeThickness="0" StrokeShape="RoundRectangle 12" Padding="10,6" VerticalOptions="Center">
                            <Label Text="Próximamente" FontSize="12" TextColor="{StaticResource ButtonsGreen}" />
                        </Border>
                    </Grid>
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentView>