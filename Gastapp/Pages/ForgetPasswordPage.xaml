<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Gastapp.Pages.ForgetPasswordPage"
             xmlns:vm="clr-namespace:Gastapp.ViewModels"
             x:DataType="vm:ForgetPasswordViewModel"
             Shell.NavBarIsVisible="False"
             Title="Recuperar contraseña">
    <ContentPage.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="{StaticResource SurfaceSecondary}" Offset="0.0" />
            <GradientStop Color="White" Offset="1.0" />
        </LinearGradientBrush>
    </ContentPage.Background>
    
    <Grid RowDefinitions="auto,*">
        <!-- Header -->
        <VerticalStackLayout Grid.Row="0" Padding="20,18,20,12" Spacing="14">
            <Grid ColumnDefinitions="auto,*" ColumnSpacing="14">
                <Border HeightRequest="44" WidthRequest="44" BackgroundColor="White" Stroke="{StaticResource BorderSubtle}" StrokeShape="RoundRectangle 22">
                    <ImageButton Source="backarrow" BackgroundColor="Transparent" WidthRequest="44" HeightRequest="44" Command="{Binding GoBackCommand}" />
                </Border>

                <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                    <Label Text="Recuperar contraseña" FontSize="28" TextColor="{StaticResource TextDarkColor}" />
                    <Label Text="Sigue los pasos para restablecer tu contraseña" FontSize="14" TextColor="{StaticResource Gray500}" FontFamily="OpenSansRegular" />
                </VerticalStackLayout>
            </Grid>

            <Border BackgroundColor="{StaticResource ButtonsGreen}" StrokeThickness="0" StrokeShape="RoundRectangle 28" Padding="20">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Restablecimiento seguro" FontSize="26" TextColor="White" />
                    <Label Text="Te enviaremos un código de verificación a tu correo para confirmar tu identidad." FontSize="14" TextColor="White" Opacity="0.9" FontFamily="OpenSansRegular" />
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>

        <!-- Content -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="20,0,20,28" Spacing="16">

                <!-- Paso 1: Correo -->
                <Border BackgroundColor="White" Stroke="{StaticResource BorderSubtle}" StrokeShape="RoundRectangle 24" Padding="20" IsVisible="{Binding ShowStep1}">
                    <VerticalStackLayout Spacing="14">
                        <Label Text="Ingresa tu correo" FontSize="20" TextColor="{StaticResource TextDarkColor}" FontFamily="BalooRegular" />
                        <Label Text="Te enviaremos un código de verificación para confirmar tu identidad." FontFamily="OpenSansRegular" TextColor="{StaticResource Gray500}" FontSize="14" />

                        <Label Text="Correo electrónico" FontAttributes="Bold" FontSize="13" />
                        <Border StrokeShape="RoundRectangle 12" StrokeThickness="1.5" Stroke="{StaticResource BorderSubtle}" BackgroundColor="{StaticResource SurfaceSecondary}" Padding="14,0">
                            <Entry Keyboard="Email" ReturnType="Done" Placeholder="nombre@correo.com" Text="{Binding Email}" FontSize="14" />
                        </Border>

                        <Button Text="Enviar código de verificación"
                            Command="{Binding SendVerificationCodeCommand}"
                            IsEnabled="{Binding CanSubmit}"
                            BackgroundColor="{StaticResource ButtonsGreen}"
                            TextColor="White"
                            FontFamily="OpenSansSemiBold"
                            CornerRadius="12"
                            Padding="16,12"
                            FontSize="14" />

                        <Label Text="{Binding StatusMessage}"
                               IsVisible="{Binding ShowStatusMessage}"
                               TextColor="{Binding StatusMessageColor}"
                               FontFamily="OpenSansRegular"
                               FontSize="13"
                               LineBreakMode="WordWrap" />
                    </VerticalStackLayout>
                </Border>

                <!-- Paso 2: Código de verificación -->
                <Border BackgroundColor="White" Stroke="{StaticResource BorderSubtle}" StrokeShape="RoundRectangle 24" Padding="20" IsVisible="{Binding ShowStep2}">
                    <VerticalStackLayout Spacing="14">
                        <Label Text="Verifica tu identidad" FontSize="20" TextColor="{StaticResource TextDarkColor}" FontFamily="BalooRegular" />
                        <Label Text="Ingresa el código que enviamos a tu correo. Revisa también tu carpeta de spam." FontFamily="OpenSansRegular" TextColor="{StaticResource Gray500}" FontSize="14" />

                        <Label Text="Código de verificación" FontAttributes="Bold" FontSize="13" />
                        <Border StrokeShape="RoundRectangle 12" StrokeThickness="1.5" Stroke="{StaticResource BorderSubtle}" BackgroundColor="{StaticResource SurfaceSecondary}" Padding="14,0">
                            <Entry Keyboard="Numeric" ReturnType="Done" Placeholder="123456" Text="{Binding VerificationCode}" FontSize="14" MaxLength="6" />
                        </Border>

                        <Button Text="Verificar código"
                            Command="{Binding VerifyCodeCommand}"
                            IsEnabled="{Binding CanSubmit}"
                            BackgroundColor="{StaticResource ButtonsGreen}"
                            TextColor="White"
                            FontFamily="OpenSansSemiBold"
                            CornerRadius="12"
                            Padding="16,12"
                            FontSize="14" />

                        <Button Text="Reenviar código"
                            Command="{Binding SendVerificationCodeCommand}"
                            IsEnabled="{Binding CanSubmit}"
                            BackgroundColor="Transparent"
                            TextColor="{StaticResource ButtonsGreen}"
                            FontFamily="OpenSansSemiBold"
                            CornerRadius="12"
                            Padding="16,8"
                            FontSize="13" />

                        <Label Text="{Binding StatusMessage}"
                               IsVisible="{Binding ShowStatusMessage}"
                               TextColor="{Binding StatusMessageColor}"
                               FontFamily="OpenSansRegular"
                               FontSize="13"
                               LineBreakMode="WordWrap" />
                    </VerticalStackLayout>
                </Border>

                <!-- Paso 3: Nueva contraseña -->
                <Border BackgroundColor="White" Stroke="{StaticResource BorderSubtle}" StrokeShape="RoundRectangle 24" Padding="20" IsVisible="{Binding ShowStep3}">
                    <VerticalStackLayout Spacing="14">
                        <Label Text="Nueva contraseña" FontSize="20" TextColor="{StaticResource TextDarkColor}" FontFamily="BalooRegular" />
                        <Label Text="Elige una contraseña segura de al menos 6 caracteres." FontFamily="OpenSansRegular" TextColor="{StaticResource Gray500}" FontSize="14" />

                        <Label Text="Nueva contraseña" FontAttributes="Bold" FontSize="13" />
                        <Border StrokeShape="RoundRectangle 12" StrokeThickness="1.5" Stroke="{StaticResource BorderSubtle}" BackgroundColor="{StaticResource SurfaceSecondary}" Padding="14,0">
                            <Entry IsPassword="True" ReturnType="Next" Placeholder="Mínimo 6 caracteres" Text="{Binding NewPassword}" FontSize="14" />
                        </Border>

                        <Label Text="Confirmar contraseña" FontAttributes="Bold" FontSize="13" />
                        <Border StrokeShape="RoundRectangle 12" StrokeThickness="1.5" Stroke="{StaticResource BorderSubtle}" BackgroundColor="{StaticResource SurfaceSecondary}" Padding="14,0">
                            <Entry IsPassword="True" ReturnType="Done" Placeholder="Repite tu contraseña" Text="{Binding ConfirmPassword}" FontSize="14" />
                        </Border>

                        <Button Text="Cambiar contraseña"
                            Command="{Binding ResetPasswordCommand}"
                            IsEnabled="{Binding CanSubmit}"
                            BackgroundColor="{StaticResource ButtonsGreen}"
                            TextColor="White"
                            FontFamily="OpenSansSemiBold"
                            CornerRadius="12"
                            Padding="16,12"
                            FontSize="14" />

                        <Label Text="{Binding StatusMessage}"
                               IsVisible="{Binding ShowStatusMessage}"
                               TextColor="{Binding StatusMessageColor}"
                               FontFamily="OpenSansRegular"
                               FontSize="13"
                               LineBreakMode="WordWrap" />
                    </VerticalStackLayout>
                </Border>

                <!-- Paso 4: Éxito -->
                <Border BackgroundColor="White" Stroke="{StaticResource BorderSubtle}" StrokeShape="RoundRectangle 24" Padding="20" IsVisible="{Binding ShowSuccessSection}">
                    <VerticalStackLayout Spacing="16">
                        <Grid ColumnDefinitions="auto,*" ColumnSpacing="12">
                            <Border Grid.Column="0"
                                    BackgroundColor="{StaticResource ButtonsGreen}"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 28"
                                    Padding="12"
                                    WidthRequest="56"
                                    HeightRequest="56"
                                    VerticalOptions="Start">
                                <Label Text="✓" FontSize="28" TextColor="White" HorizontalOptions="Center" VerticalOptions="Center" />
                            </Border>

                            <VerticalStackLayout Grid.Column="1" Spacing="6" VerticalOptions="Center">
                                <Label Text="¡Contraseña restablecida!" FontSize="20" TextColor="{StaticResource TextDarkColor}" FontFamily="BalooRegular" />
                                <Label Text="Ya puedes iniciar sesión con tu nueva contraseña" FontSize="13" TextColor="{StaticResource Gray500}" FontFamily="OpenSansRegular" />
                            </VerticalStackLayout>
                        </Grid>

                        <BoxView BackgroundColor="{StaticResource BorderSubtle}" HeightRequest="1" />

                        <Button Text="Ir a iniciar sesión"
                                Command="{Binding GoToLoginCommand}"
                                BackgroundColor="{StaticResource ButtonsGreen}"
                                TextColor="White"
                                FontFamily="OpenSansSemiBold"
                                CornerRadius="12"
                                Padding="16,12"
                                FontSize="14" />
                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>