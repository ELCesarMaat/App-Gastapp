<?xml version="1.0" encoding="utf-8"?>

<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:Gastapp.Models;assembly=Gastapp.Models"
             xmlns:progressBar="clr-namespace:Syncfusion.Maui.ProgressBar;assembly=Syncfusion.Maui.ProgressBar"
             xmlns:vm="clr-namespace:Gastapp.ViewModels"
             x:Class="Gastapp.Pages.Menu.SavesPage"
             x:Name="SavesRoot"
             x:DataType="vm:SavesViewModel">
    <ContentView.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="{Binding HealthSurfaceColor}" Offset="0.0" />
            <GradientStop Color="#F8FCFA" Offset="0.55" />
            <GradientStop Color="#FFFFFF" Offset="1.0" />
        </LinearGradientBrush>
    </ContentView.Background>

    <ScrollView>
        <VerticalStackLayout Padding="20,18,20,28" Spacing="18">
            <Border BackgroundColor="White"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 30"
                    Padding="22,20">
                <VerticalStackLayout Spacing="14">
                    <VerticalStackLayout Spacing="2">
                        <Label Text="Estadisticas de gastos"
                               FontSize="28"
                               TextColor="{StaticResource TextDarkColor}" />
                        <Label Text="{Binding PeriodLabel}"
                               FontSize="14"
                               FontFamily="OpenSansRegular"
                               TextColor="{StaticResource Gray500}" />
                        <Label Text="{Binding PeriodCaption}"
                               FontSize="13"
                               FontFamily="OpenSansRegular"
                               TextColor="{StaticResource Gray500}" />
                    </VerticalStackLayout>

                    <Grid ColumnDefinitions="auto,*,auto" ColumnSpacing="10">
                        <Border BackgroundColor="#F0F7F4" StrokeThickness="0" StrokeShape="RoundRectangle 14" Padding="10,8">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding PreviousPeriodCommand}" />
                            </Border.GestureRecognizers>
                            <Label Text="Anterior" TextColor="{StaticResource TextDarkColor}" FontSize="13" FontFamily="OpenSansRegular" />
                        </Border>

                        <Label Grid.Column="1"
                               Text="{Binding ActivePeriodLabel}"
                               FontSize="13"
                               FontFamily="OpenSansRegular"
                               TextColor="{StaticResource Gray500}"
                               HorizontalTextAlignment="Center"
                               VerticalTextAlignment="Center"
                               LineBreakMode="TailTruncation" />

                        <Border Grid.Column="2" BackgroundColor="#F0F7F4" StrokeThickness="0" StrokeShape="RoundRectangle 14" Padding="10,8">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding NextPeriodCommand}" />
                            </Border.GestureRecognizers>
                            <Border.Triggers>
                                <DataTrigger TargetType="Border" Binding="{Binding CanGoToNewerPeriod}" Value="False">
                                    <Setter Property="Opacity" Value="0.4" />
                                </DataTrigger>
                            </Border.Triggers>
                            <Label Text="Siguiente" TextColor="{StaticResource TextDarkColor}" FontSize="13" FontFamily="OpenSansRegular" />
                        </Border>
                    </Grid>

                    <Grid ColumnDefinitions="*,auto" ColumnSpacing="10">
                        <VerticalStackLayout Spacing="2">
                            <Label Text="Total gastado"
                                   FontSize="14"
                                   FontFamily="OpenSansRegular"
                                   TextColor="{StaticResource Gray500}" />
                            <Label Text="{Binding TotalSpending, StringFormat='${0:N2}'}"
                                   FontSize="40"
                                   TextColor="{StaticResource TextDarkColor}" />
                        </VerticalStackLayout>

                        <Border BackgroundColor="{Binding HealthSurfaceColor}"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 18"
                                Padding="14,8"
                                VerticalOptions="Start"
                                HorizontalOptions="End">
                            <Label Text="{Binding HealthText}"
                                   FontSize="16"
                                   TextColor="{Binding HealthTextColor}"
                                   HorizontalTextAlignment="Center" />
                        </Border>
                    </Grid>

                    <Label Text="{Binding HealthMessage}"
                           FontSize="14"
                           FontFamily="OpenSansRegular"
                           TextColor="{StaticResource TextDarkColor}"
                           LineBreakMode="WordWrap" />

                          <Border IsVisible="{Binding IsPastPeriodSelected}"
                            BackgroundColor="#F6FBF8"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 20"
                            Padding="14,12">
                           <VerticalStackLayout Spacing="2">
                            <Label Text="{Binding SavedAmountInPeriodTitle}"
                                FontSize="14"
                                FontFamily="OpenSansRegular"
                                TextColor="{StaticResource Gray500}" />
                            <Label Text="{Binding SavedAmountInPeriod, StringFormat='${0:N2}'}"
                                FontSize="30"
                                TextColor="{Binding SavedAmountInPeriodColor}" />
                            <Label Text="{Binding SavedAmountInPeriodCaption}"
                                FontSize="12"
                                FontFamily="OpenSansRegular"
                                TextColor="{StaticResource Gray500}"
                                LineBreakMode="WordWrap" />
                           </VerticalStackLayout>
                          </Border>
                </VerticalStackLayout>
            </Border>

            <Border BackgroundColor="White"
                    Stroke="{StaticResource BorderSubtle}"
                    StrokeShape="RoundRectangle 30"
                    Padding="20">
                <VerticalStackLayout Spacing="18">
                    <Label Text="Uso de presupuesto"
                           FontSize="24"
                           TextColor="{StaticResource TextDarkColor}" />

                    <VerticalStackLayout HorizontalOptions="Center" Spacing="10">
                        <progressBar:SfCircularProgressBar Progress="{Binding ProgressPercent}"
                                                           StartAngle="270"
                                                           EndAngle="269.9"
                                                           TrackThickness="12"
                                                           ProgressThickness="8"
                                                           TrackFill="#E7EFEC"
                                                           ProgressFill="{Binding HealthColor}"
                                                           WidthRequest="180"
                                                           HeightRequest="180">
                            <progressBar:SfCircularProgressBar.Content>
                                <VerticalStackLayout Spacing="-2"
                                                     HorizontalOptions="Center"
                                                     VerticalOptions="Center">
                                    <Label Text="{Binding Percent, StringFormat='{0:N0}%'}"
                                           HorizontalTextAlignment="Center"
                                           FontSize="25"
                                           TextColor="{StaticResource TextDarkColor}" />
                                    <Label Text="del limite"
                                           HorizontalTextAlignment="Center"
                                           FontSize="13"
                                           FontFamily="OpenSansRegular"
                                           TextColor="{StaticResource Gray500}" />
                                </VerticalStackLayout>
                            </progressBar:SfCircularProgressBar.Content>
                        </progressBar:SfCircularProgressBar>

                        <Label Text="{Binding SpendingVsBudgetText}"
                               FontSize="15"
                               FontFamily="OpenSansRegular"
                               TextColor="{StaticResource Gray500}" />
                    </VerticalStackLayout>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                        <Border Grid.Column="0"
                                BackgroundColor="{Binding HealthSurfaceColor}"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 22"
                                Padding="16,14">
                            <VerticalStackLayout Spacing="2">
                                <Label Text="{Binding BudgetBalanceTitle}"
                                       FontSize="14"
                                       FontFamily="OpenSansRegular"
                                       TextColor="{Binding HealthTextColor}" />
                                <Label Text="{Binding RemainingBudget, StringFormat='${0:N2}'}"
                                       FontSize="24"
                                       TextColor="{StaticResource TextDarkColor}" />
                                <Label Text="{Binding BudgetBalanceCaption}"
                                       FontSize="12"
                                       FontFamily="OpenSansRegular"
                                       TextColor="{StaticResource Gray500}"
                                       LineBreakMode="WordWrap" />
                            </VerticalStackLayout>
                        </Border>

                        <Border Grid.Column="1"
                                BackgroundColor="#F6FBF8"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 22"
                                Padding="16,14">
                            <VerticalStackLayout Spacing="2">
                                <Label Text="Promedio diario"
                                       FontSize="14"
                                       FontFamily="OpenSansRegular"
                                       TextColor="{StaticResource Gray500}" />
                                <Label Text="{Binding DailyAverage, StringFormat='${0:N2}'}"
                                       FontSize="24"
                                       TextColor="{StaticResource TextDarkColor}" />
                                <Label Text="Calculado con los dias de tu periodo activo."
                                       FontSize="12"
                                       FontFamily="OpenSansRegular"
                                       TextColor="{StaticResource Gray500}"
                                       LineBreakMode="WordWrap" />
                            </VerticalStackLayout>
                        </Border>
                    </Grid>

                    <Border BackgroundColor="#F8FBFA"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 22"
                            Padding="16,14">
                        <VerticalStackLayout Spacing="2">
                            <Label Text="Categoria principal"
                                   FontSize="14"
                                   FontFamily="OpenSansRegular"
                                   TextColor="{StaticResource Gray500}" />
                            <Label Text="{Binding TopCategoryName}"
                                   FontSize="24"
                                   TextColor="{StaticResource TextDarkColor}" />
                            <Label Text="{Binding TopCategorySummary}"
                                   FontSize="12"
                                   FontFamily="OpenSansRegular"
                                   TextColor="{StaticResource Gray500}"
                                   LineBreakMode="WordWrap" />
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>
            </Border>

            <Border BackgroundColor="White"
                    Stroke="{StaticResource BorderSubtle}"
                    StrokeShape="RoundRectangle 30"
                    Padding="20">
                <VerticalStackLayout Spacing="14">
                    <VerticalStackLayout Spacing="2">
                        <Label Text="Distribucion por categoria"
                               FontSize="24"
                               TextColor="{StaticResource TextDarkColor}" />
                        <Label Text="Cada barra representa el peso real de esa categoria dentro de tus gastos del periodo."
                               FontSize="13"
                               FontFamily="OpenSansRegular"
                               TextColor="{StaticResource Gray500}"
                               LineBreakMode="WordWrap" />
                    </VerticalStackLayout>

                    <Border BackgroundColor="#F8FBFA"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 22"
                            Padding="18">
                        <Border.Triggers>
                            <DataTrigger TargetType="Border" Binding="{Binding HasSpendings}" Value="True">
                                <Setter Property="IsVisible" Value="False" />
                            </DataTrigger>
                        </Border.Triggers>
                        <VerticalStackLayout Spacing="8">
                            <Label Text="Todavia no hay gastos para mostrar."
                                   FontSize="22"
                                   HorizontalTextAlignment="Center"
                                   TextColor="{StaticResource TextDarkColor}" />
                            <Label Text="Cuando registres movimientos, aqui veras la distribucion real por categoria."
                                   FontSize="13"
                                   FontFamily="OpenSansRegular"
                                   HorizontalTextAlignment="Center"
                                   TextColor="{StaticResource Gray500}"
                                   LineBreakMode="WordWrap" />
                        </VerticalStackLayout>
                    </Border>

                    <VerticalStackLayout BindableLayout.ItemsSource="{Binding Data}"
                                         IsVisible="{Binding HasSpendings}"
                                         Spacing="10">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="models:CategoryResume">
                                <Border BackgroundColor="#F8FBFA"
                                        StrokeThickness="0"
                                        StrokeShape="RoundRectangle 22"
                                        Padding="14,12">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={x:Reference SavesRoot}, Path=BindingContext.OpenCategoryCommand}"
                                            CommandParameter="{Binding .}" />
                                    </Border.GestureRecognizers>
                                    <VerticalStackLayout Spacing="8">
                                        <Grid ColumnDefinitions="*,110"
                                              ColumnSpacing="12"
                                              VerticalOptions="Center">
                                            <VerticalStackLayout Spacing="2"
                                                                 HorizontalOptions="Fill">
                                                <Label Text="{Binding Name}"
                                                       FontSize="19"
                                                       TextColor="{StaticResource TextDarkColor}"
                                                       LineBreakMode="TailTruncation"
                                                       MaxLines="1" />
                                                <Label Text="{Binding SummaryText}"
                                                       FontSize="12"
                                                       FontFamily="OpenSansRegular"
                                                       TextColor="{StaticResource Gray500}"
                                                       LineBreakMode="TailTruncation"
                                                       MaxLines="1" />
                                            </VerticalStackLayout>

                                            <Label Grid.Column="1"
                                                   Text="{Binding Amount, StringFormat='${0:N2}'}"
                                                   FontSize="18"
                                                   TextColor="{StaticResource TextDarkColor}"
                                                   HorizontalOptions="End"
                                                   HorizontalTextAlignment="End"
                                                   VerticalOptions="Center"
                                                   LineBreakMode="NoWrap" />
                                        </Grid>
                                        <Border HeightRequest="8" Padding="0" BackgroundColor="#E7EFEC" StrokeThickness="0" StrokeShape="RoundRectangle 5">
                                            <ProgressBar Progress="{Binding ProgressValue}"
                                                         ProgressColor="{Binding AccentColor}"
                                                         BackgroundColor="White"
                                                         ScaleY="2"
                                                         HeightRequest="4" />
                                        </Border>
                                    </VerticalStackLayout>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentView>
