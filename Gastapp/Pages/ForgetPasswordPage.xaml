<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Gastapp.Pages.ForgetPasswordPage"
             xmlns:vm="clr-namespace:Gastapp.ViewModels"
             x:DataType="vm:ForgetPasswordViewModel"
             Shell.NavBarIsVisible="False"
             Title="Recuperar contraseña">
    <ContentPage.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="{StaticResource SurfaceSecondary}" Offset="0.0" />
            <GradientStop Color="White" Offset="1.0" />
        </LinearGradientBrush>
    </ContentPage.Background>
    
    <Grid RowDefinitions="auto,*">
        <!-- Header -->
        <VerticalStackLayout Grid.Row="0" Padding="20,18,20,12" Spacing="14">
            <Grid ColumnDefinitions="auto,*" ColumnSpacing="14">
                <Border HeightRequest="44" WidthRequest="44" BackgroundColor="White" Stroke="{StaticResource BorderSubtle}" StrokeShape="RoundRectangle 22">
                    <ImageButton Source="backarrow" BackgroundColor="Transparent" WidthRequest="44" HeightRequest="44" Command="{Binding GoBackCommand}" />
                </Border>

                <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                    <Label Text="Recuperar contraseña" FontSize="28" TextColor="{StaticResource TextDarkColor}" />
                    <Label Text="Solicita una contraseña temporal para acceder a tu cuenta" FontSize="14" TextColor="{StaticResource Gray500}" FontFamily="OpenSansRegular" />
                </VerticalStackLayout>
            </Grid>

            <Border BackgroundColor="{StaticResource ButtonsGreen}" StrokeThickness="0" StrokeShape="RoundRectangle 28" Padding="20">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Restablecimiento rápido" FontSize="26" TextColor="White" />
                    <Label Text="Te enviaremos una contraseña temporal a tu correo. Úsala para iniciar sesión." FontSize="14" TextColor="White" Opacity="0.9" FontFamily="OpenSansRegular" />
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>

        <!-- Content -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="20,0,20,28" Spacing="16">
                
                <!-- Email Request Section (Initially Visible) -->
                <Border BackgroundColor="White" Stroke="{StaticResource BorderSubtle}" StrokeShape="RoundRectangle 24" Padding="20" IsVisible="{Binding PasswordSent, Converter={StaticResource InvertedBoolConverter}}">
                    <VerticalStackLayout Spacing="14">
                        <Label Text="Solicitar contraseña temporal" FontSize="20" TextColor="{StaticResource TextDarkColor}" FontFamily="BalooRegular" />
                        <Label Text="Ingresa tu correo electrónico y te enviaremos una contraseña temporal para que accedas a tu cuenta." FontFamily="OpenSansRegular" TextColor="{StaticResource Gray500}" FontSize="14" />
                        
                        <Label Text="Correo electrónico" FontAttributes="Bold" FontSize="13" />
                        <Border StrokeShape="RoundRectangle 12" StrokeThickness="1.5" Stroke="{StaticResource BorderSubtle}" BackgroundColor="{StaticResource SurfaceSecondary}" Padding="14,0">
                            <Entry Keyboard="Email" ReturnType="Done" Placeholder="nombre@correo.com" Text="{Binding Email}" IsEnabled="{Binding IsEmailEnabled}" FontSize="14" />
                        </Border>
                        
                        <Button Text="Enviar contraseña temporal" 
                                Command="{Binding RequestTemporaryPasswordCommand}" 
                                IsEnabled="{Binding IsProcessing, Converter={StaticResource InvertedBoolConverter}}"
                                BackgroundColor="{StaticResource ButtonsGreen}"
                                TextColor="White"
                                FontFamily="OpenSansSemiBold"
                                CornerRadius="12"
                                Padding="16,12"
                                FontSize="14" />
                        
                        <!-- Status Message -->
                        <Label Text="{Binding StatusMessage}" 
                               IsVisible="{Binding ShowStatusMessage}" 
                               TextColor="{Binding StatusMessageColor}" 
                               FontFamily="OpenSansRegular"
                               FontSize="13"
                               LineBreakMode="WordWrap" />
                    </VerticalStackLayout>
                </Border>

                <!-- Success Section (Visible after sending) -->
                <Border BackgroundColor="White" Stroke="{StaticResource BorderSubtle}" StrokeShape="RoundRectangle 24" Padding="20" IsVisible="{Binding PasswordSent}">
                    <VerticalStackLayout Spacing="16">
                        <Grid ColumnDefinitions="auto,*" ColumnSpacing="12">
                            <Border Grid.Column="0" 
                                    BackgroundColor="{StaticResource ButtonsGreen}" 
                                    StrokeThickness="0" 
                                    StrokeShape="RoundRectangle 28"
                                    Padding="12"
                                    WidthRequest="56"
                                    HeightRequest="56"
                                    VerticalOptions="Start">
                                <Label Text="✓" FontSize="28" TextColor="White" HorizontalOptions="Center" VerticalOptions="Center" />
                            </Border>
                            
                            <VerticalStackLayout Grid.Column="1" Spacing="6" VerticalOptions="Center">
                                <Label Text="¡Listo!" FontSize="20" TextColor="{StaticResource TextDarkColor}" FontFamily="BalooRegular" />
                                <Label Text="Contraseña temporal enviada" FontSize="13" TextColor="{StaticResource Gray500}" FontFamily="OpenSansRegular" />
                            </VerticalStackLayout>
                        </Grid>

                        <BoxView BackgroundColor="{StaticResource BorderSubtle}" HeightRequest="1" />
                        
                        <VerticalStackLayout Spacing="10">
                            <Label Text="{Binding StatusMessage}" 
                                   TextColor="{Binding StatusMessageColor}" 
                                   FontFamily="OpenSansRegular"
                                   FontSize="13"
                                   LineBreakMode="WordWrap" />
                            
                            <Button Text="Ir a iniciar sesión" 
                                    Command="{Binding GoToLoginCommand}"
                                    BackgroundColor="{StaticResource ButtonsGreen}"
                                    TextColor="White"
                                    FontFamily="OpenSansSemiBold"
                                    CornerRadius="12"
                                    Padding="16,12"
                                    FontSize="14" />
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>