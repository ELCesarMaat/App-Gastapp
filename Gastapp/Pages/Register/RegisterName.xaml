<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Gastapp.Pages.Register.RegisterName"
             xmlns:vm="clr-namespace:Gastapp.ViewModels"
             x:DataType="vm:RegisterViewModel"
             >
    <VerticalStackLayout Padding="24" Spacing="10" VerticalOptions="Center">
        <Label Text="Este nombre aparecerá en tu perfil y mensajes principales."
               FontFamily="OpenSansRegular" TextColor="{StaticResource Gray500}" />
        <Label Text="Tu nombre" FontAttributes="Bold" FontSize="16" />
        <Entry Keyboard="Text" Text="{Binding Name}" ReturnType="Done" Placeholder="¿Cómo quieres que te llamemos?" />
        <Label Text="{Binding NameErrorMessage}" IsVisible="{Binding NameHasError}" TextColor="Red" Padding="0"/>
    </VerticalStackLayout>
</ContentView>