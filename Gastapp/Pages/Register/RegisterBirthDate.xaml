<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Gastapp.Pages.Register.RegisterBirthDate"
             xmlns:vm="clr-namespace:Gastapp.ViewModels"
             x:DataType="vm:RegisterViewModel"
             >
    <Grid
     RowDefinitions="auto, auto, *"
        ColumnDefinitions=".3*, .4*, .3*"
     Padding="24"
     >
        <Label Grid.ColumnSpan="3" Text="Selecciona día, mes y año." FontFamily="OpenSansRegular"
               TextColor="{StaticResource Gray500}" Margin="0, 0, 0, 16" />

        <Border Grid.Row="1" Grid.Column="0" StrokeShape="RoundRectangle 12" Margin="4, 0, 4, 0" Stroke="{StaticResource BorderSubtle}">
            <VerticalStackLayout>
                <Label Text="Año" HorizontalOptions="Center" FontSize="15"/>
                <Picker ItemsSource="{Binding ListYears}" SelectedItem="{Binding SelectedYear, Mode=TwoWay}" Margin="0, -5, 0, 0"
                        HorizontalTextAlignment="Center" FontAttributes="Bold"/>
            </VerticalStackLayout>
        </Border>

        <Border Grid.Row="1" Grid.Column="1" StrokeShape="RoundRectangle 12" Margin="4, 0, 4, 0" Stroke="{StaticResource BorderSubtle}">
            <VerticalStackLayout>
                <Label Text="Mes" HorizontalOptions="Center" FontSize="15"/>
                <Picker ItemsSource="{Binding ListMonths}" SelectedItem="{Binding SelectedMonth, Mode=TwoWay}" Margin="0, -5, 0, 0"
                        HorizontalTextAlignment="Center" FontAttributes="Bold"/>
            </VerticalStackLayout>
        </Border>


        <Border Grid.Row="1" Grid.Column="2" StrokeShape="RoundRectangle 12" Margin="0, 0, 4, 0" Stroke="{StaticResource BorderSubtle}">
            <VerticalStackLayout>
                <Label Text="Día" HorizontalOptions="Center" FontSize="15" Background="Transparent" />
                <Picker ItemsSource="{Binding ListDays}" SelectedItem="{Binding SelectedDay, Mode=TwoWay}" Margin="0, -5, 0, 0"
                        HorizontalTextAlignment="Center" FontAttributes="Bold"/>
            </VerticalStackLayout>
        </Border>

    </Grid>
</ContentView>