<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Gastapp.Controls.GastappLargeButton"
             xmlns:toolkit="clr-namespace:CommunityToolkit.Maui;assembly=CommunityToolkit.Maui"
             x:Name="this"
             >

    <Border
        StrokeShape="RoundRectangle 10"
        Stroke="{Binding BorderColor, Source={x:Reference this}}"
        BackgroundColor="{Binding BackgroundColorCustom, Source={x:Reference this}}"
        Padding="5"
        Margin="{Binding ButtonMargin, Source={x:Reference this}}">

        <Label
            Text="{Binding Text, Source={x:Reference this}}"
            TextColor="{Binding TextColor, Source={x:Reference this}}"
            HorizontalOptions="Center"
            FontSize="16"
            FontAttributes="Bold"
            Margin="5"/>


        <Border.GestureRecognizers>
            <TapGestureRecognizer Tapped="OnTapped"/> 
        </Border.GestureRecognizers>

    </Border>
</ContentView>
