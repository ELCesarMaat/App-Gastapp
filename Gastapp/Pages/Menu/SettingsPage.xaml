<?xml version="1.0" encoding="utf-8"?>

<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Gastapp.Pages.Menu.SettingsPage"
             xmlns:vm="clr-namespace:Gastapp.ViewModels"
             x:DataType="vm:SettingsViewModel">
    <ContentView.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="{StaticResource SurfaceSecondary}" Offset="0.0" />
            <GradientStop Color="White" Offset="1.0" />
        </LinearGradientBrush>
    </ContentView.Background>
    <ScrollView>
        <VerticalStackLayout Padding="20, 18, 20, 28" Spacing="16">
            <Border BackgroundColor="{StaticResource ButtonsGreen}" StrokeThickness="0" StrokeShape="RoundRectangle 28" Padding="20">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Ajustes" FontSize="28" TextColor="White" />
                    <Label Text="{Binding ScreenSubtitle}" FontFamily="OpenSansRegular" FontSize="14" TextColor="White" Opacity="0.92" />
                </VerticalStackLayout>
            </Border>

            <Border BackgroundColor="White" Stroke="{StaticResource BorderSubtle}" StrokeShape="RoundRectangle 24" Padding="18">
                <VerticalStackLayout Spacing="12">
                    <Label Text="Recordatorios" FontSize="22" TextColor="{StaticResource TextDarkColor}" />
                    <Label Text="{Binding NotificationsStatusText}" FontFamily="OpenSansRegular" TextColor="{StaticResource Gray500}" />

                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                        <Label Text="Activar recordatorios" VerticalOptions="Center" FontSize="16" TextColor="{StaticResource TextDarkColor}" />
                        <Switch Grid.Column="1" IsToggled="{Binding IsRemindersEnabled}" />
                    </Grid>

                    <Picker Title="Frecuencia de recordatorios"
                            ItemsSource="{Binding ReminderFrequencyOptions}"
                            ItemDisplayBinding="{Binding Label}"
                            SelectedItem="{Binding SelectedReminderFrequencyOption}"
                            IsEnabled="{Binding IsRemindersEnabled}" />

                    <Button Text="Activar notificaciones del sistema"
                            IsVisible="{Binding ShowEnableNotificationsButton}"
                            Command="{Binding EnableSystemNotificationsCommand}"
                            BackgroundColor="{StaticResource ButtonsGreen}"
                            TextColor="White" />

                    <Label Text="Se guardan automáticamente al cambiar la frecuencia o activación."
                           FontFamily="OpenSansRegular"
                           TextColor="{StaticResource Gray500}" />

                    <Button Text="Enviar notificación de prueba"
                            Command="{Binding SendTestNotificationCommand}"
                            BackgroundColor="White"
                            TextColor="{StaticResource ButtonsGreen}"
                            BorderColor="{StaticResource ButtonsGreen}"
                            BorderWidth="1" />
                </VerticalStackLayout>
            </Border>

            <Border BackgroundColor="#FFF1F1" Stroke="#F5CDCD" StrokeShape="RoundRectangle 24" Padding="18">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Cerrar sesión" FontSize="22" TextColor="{StaticResource TextDarkColor}" />
                    <Label Text="Usa esta acción cuando quieras salir del dispositivo actual. Borrará la sesión local para proteger tu información." FontFamily="OpenSansRegular" TextColor="{StaticResource Gray500}" />
                    <Button Text="Cerrar sesión" Command="{Binding LogoutCommand}" BackgroundColor="{StaticResource ErrorColor}" TextColor="White" />
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentView>