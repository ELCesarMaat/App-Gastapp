<?xml version="1.0" encoding="utf-8"?>

<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Gastapp.Pages.Menu.SummaryPage"
             xmlns:vm="clr-namespace:Gastapp.ViewModels"
             xmlns:models="clr-namespace:Gastapp.Models"
             x:DataType="vm:SummaryViewModel">
    <ScrollView>
        <Grid Margin="20, 0, 20, 0"
              RowDefinitions="auto, auto, auto, auto">
            <FlexLayout JustifyContent="SpaceBetween">
                <Label Text="VIERNES 5 ABRIL" Margin="0" FontSize="20" TextColor="White" />
                <Border HorizontalOptions="End" Padding="0" StrokeThickness="0">
                    <VerticalStackLayout Spacing="0" Margin="0, 0, 0, 5">
                        <Label Text="Ver mas" TextColor="White" FontSize="12" Padding="0" />
                        <Label Text="&lt; &gt;" TextColor="White" HorizontalTextAlignment="Center" FontSize="20"
                               Padding="-10" />
                    </VerticalStackLayout>
                </Border>
            </FlexLayout>
            <CollectionView Grid.Row="1" SelectionMode="Single" FlowDirection="LeftToRight">
                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Horizontal" ItemSpacing="5" />
                </CollectionView.ItemsLayout>
                <CollectionView.ItemsSource>
                    <x:Array Type="{x:Type x:String}">
                        <x:String>1</x:String>
                        <x:String>2</x:String>
                        <x:String>3</x:String>
                        <x:String>4</x:String>
                        <x:String>5</x:String>
                        <x:String>6</x:String>
                        <x:String>7</x:String>


                    </x:Array>
                </CollectionView.ItemsSource>
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border BackgroundColor="#00C6CD" Padding="0"
                                HeightRequest="60" WidthRequest="60" StrokeThickness="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="30" />
                            </Border.StrokeShape>
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup Name="CommonStates">
                                    <VisualState Name="Normal">
                                        <VisualState.Setters>
                                            <Setter Property="Stroke"
                                                    Value="Transparent" />
                                            <Setter Property="StrokeThickness"
                                                    Value="0" />
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState Name="Selected">
                                        <VisualState.Setters>
                                            <Setter Property="Stroke"
                                                    Value="DarkGreen" />
                                            <Setter Property="StrokeThickness"
                                                    Value="3" />
                                            <Setter Property="BackgroundColor"
                                                    Value="#198E92" />
                                        </VisualState.Setters>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                            <VerticalStackLayout HorizontalOptions="Center">
                                <Label Text="Lunes" TextColor="White" FontSize="12"
                                       Padding="0, 5, 0, -5" />

                                <Label Text="{Binding .}" TextColor="White" FontSize="30"
                                       HorizontalTextAlignment="Center"
                                       Padding="0, -5, 0, 0" />

                            </VerticalStackLayout>

                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Grid ColumnDefinitions="auto, *"
                  RowDefinitions="auto, auto"
                  Margin="0, 10"
                  Grid.Row="2">

                <Label Text="GASTOS DEL DIA" Margin="0" FontSize="22"
                       TextColor="White" />

                <Label Text="TOTAL GASTADO" Margin="0" FontSize="15"
                       Grid.Row="1"
                       TextColor="White" />

                <Label Text="{Binding TotalAmount, StringFormat='${0}'}" Margin="0" FontSize="45"
                       Grid.Row="0" Grid.Column="1" Grid.RowSpan="2"
                       HorizontalOptions="End"
                       VerticalOptions="Center"
                       HorizontalTextAlignment="Center"
                       TextColor="White" />

            </Grid>

            <CollectionView Grid.Row="3" SelectionMode="None"
                            ItemsSource="{Binding Spendings, Mode=TwoWay}">
                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Vertical" ItemSpacing="8" />
                </CollectionView.ItemsLayout>

                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:Spending">
                        <SwipeView>
                            <SwipeView.RightItems>
                                <SwipeItems Mode="Reveal">
                                    <SwipeItemView
                                        BackgroundColor="Transparent"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:SummaryViewModel}},
                                          Path=DeleteSpendingCommand}"
                                        CommandParameter="{Binding .}">
                                        <Border HeightRequest="65" WidthRequest="65" Stroke="#FF7575" StrokeThickness="2"
                                                StrokeShape="RoundRectangle 33" BackgroundColor="#FF3535">
                                            <Image Source="icon_trash" Aspect="Center"/>
                                        </Border>
                                    </SwipeItemView>

                                </SwipeItems>
                            </SwipeView.RightItems>

                            <Border BackgroundColor="#198E92" StrokeThickness="0"
                                    StrokeShape="RoundRectangle 100">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:SummaryViewModel}},
                                          Path=SpendingClickedCommand}"
                                        CommandParameter="{Binding .}" />

                                </Border.GestureRecognizers>

                                <FlexLayout JustifyContent="Start">
                                    <Label HorizontalTextAlignment="Center"
                                           VerticalOptions="Center"
                                           FontSize="25" TextColor="White"
                                           Padding="5"
                                           Text="{Binding Amount, StringFormat='${0}'}" />
                                    <Border BackgroundColor="#00C6CD" FlexLayout.Grow="1"
                                            StrokeThickness="0"
                                            Padding="8"
                                            StrokeShape="RoundRectangle 100">
                                        <VerticalStackLayout Padding="20, 0, 0, 0">
                                            <Label Text="{Binding Title}"
                                                   HorizontalTextAlignment="Center"
                                                   FontSize="27"
                                                   TextColor="White"
                                                   Padding="-5" />
                                            <Label Text="{Binding Description}"
                                                   TextColor="White"
                                                   Padding="-5" />
                                            <Label Text="{Binding Date, StringFormat='{0:dd/MM/yyyy hh:mm tt}'}"
                                                   TextColor="White"
                                                   Padding="-5" />
                                        </VerticalStackLayout>
                                    </Border>
                                </FlexLayout>
                            </Border>

                        </SwipeView>
                    </DataTemplate>
                </CollectionView.ItemTemplate>

            </CollectionView>

        </Grid>
    </ScrollView>
</ContentView>