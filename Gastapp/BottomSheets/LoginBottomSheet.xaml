<?xml version="1.0" encoding="utf-8"?>

<bs:BottomSheet xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                x:Class="Gastapp.BottomSheets.LoginBottomSheet"
                xmlns:bs="https://schemas.the49.com/dotnet/2023/maui"
                HasBackdrop="True"
                HasHandle="True"
                IsCancelable="True"
                CornerRadius="0"
                xmlns:vm="clr-namespace:Gastapp.ViewModels"
                x:DataType="vm:StartPageViewModel">
    <bs:BottomSheet.Detents>
        <bs:RatioDetent Ratio=".65" IsDefault="True"/>
        <bs:RatioDetent Ratio=".85"/>
    </bs:BottomSheet.Detents>

    <Border StrokeShape="RoundRectangle 24, 24, 0, 0"
            StrokeThickness="0"
            BackgroundColor="{StaticResource SurfacePrimary}">
        <ScrollView>
            <VerticalStackLayout Padding="24,12,24,36" Spacing="0">

                <!-- Header -->
                <Label
                    Text="Iniciar sesión"
                    FontSize="22"
                    FontFamily="BalooRegular"
                    TextColor="{StaticResource TextDarkColor}"
                    HorizontalOptions="Center"
                    Margin="0,12,0,6"/>
                <Label
                    Text="Ingresa tus datos para continuar"
                    FontSize="13"
                    TextColor="{StaticResource NavInactiveText}"
                    HorizontalTextAlignment="Center"
                    Margin="0,0,0,28"/>

                <!-- Email field -->
                <Label
                    Text="Correo electrónico"
                    FontSize="13"
                    FontAttributes="Bold"
                    TextColor="{StaticResource TextDarkColor}"
                    Margin="4,0,0,6"/>
                <Border StrokeShape="RoundRectangle 12"
                        StrokeThickness="1.5"
                        Stroke="{StaticResource BorderSubtle}"
                        BackgroundColor="{StaticResource SurfaceSecondary}"
                        Padding="14,0">
                    <Entry
                        Keyboard="Email"
                        ReturnType="Next"
                        Placeholder="tuemail@dominio.com"
                        Text="{Binding Email}"
                        HeightRequest="48"
                        SemanticProperties.Description="Campo de correo electrónico"/>
                </Border>

                <!-- Password field -->
                <Label
                    Text="Contraseña"
                    FontSize="13"
                    FontAttributes="Bold"
                    TextColor="{StaticResource TextDarkColor}"
                    Margin="4,20,0,6"/>
                <Border StrokeShape="RoundRectangle 12"
                        StrokeThickness="1.5"
                        Stroke="{StaticResource BorderSubtle}"
                        BackgroundColor="{StaticResource SurfaceSecondary}"
                        Padding="14,0,8,0">
                    <Grid ColumnDefinitions="*, 44">
                        <Entry
                            Grid.Column="0"
                            ReturnType="Done"
                            Placeholder="Tu contraseña"
                            Text="{Binding Password}"
                            IsPassword="{Binding IsPasswordHidden}"
                            HeightRequest="48"
                            SemanticProperties.Description="Campo de contraseña"/>
                        <Button
                            Grid.Column="1"
                            Text="&#x1F441;"
                            HeightRequest="40"
                            WidthRequest="44"
                            Padding="0"
                            BackgroundColor="Transparent"
                            TextColor="{StaticResource NavInactiveText}"
                            FontSize="18"
                            VerticalOptions="Center"
                            Command="{Binding TogglePasswordVisibilityCommand}"
                            SemanticProperties.Description="Mostrar u ocultar contraseña"/>
                    </Grid>
                </Border>

                <!-- Forgot password -->
                <Label
                    Text="¿Olvidaste tu contraseña?"
                    TextColor="{StaticResource LinkColor}"
                    FontSize="13"
                    HorizontalOptions="End"
                    Padding="4"
                    Margin="0,10,0,0">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoToForgotPasswordCommand}"/>
                    </Label.GestureRecognizers>
                </Label>

                <!-- Error message -->
                <Border
                    IsVisible="{Binding HasLoginError}"
                    StrokeShape="RoundRectangle 10"
                    StrokeThickness="0"
                    BackgroundColor="#FFEBEE"
                    Padding="14,10"
                    Margin="0,16,0,0">
                    <Label
                        Text="{Binding ErrorMessage}"
                        TextColor="{StaticResource ErrorColor}"
                        FontSize="13"
                        HorizontalTextAlignment="Center"/>
                </Border>

                <!-- Login button -->
                <Button
                    Text="Iniciar sesión"
                    Command="{Binding LoginCommand}"
                    HeightRequest="52"
                    FontSize="16"
                    FontAttributes="Bold"
                    Margin="0,20,0,0"/>

            </VerticalStackLayout>
        </ScrollView>
    </Border>
</bs:BottomSheet>