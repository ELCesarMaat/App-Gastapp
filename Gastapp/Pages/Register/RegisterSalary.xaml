<?xml version="1.0" encoding="utf-8"?>

<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Gastapp.Pages.Register.RegisterSalary"
             xmlns:sf="clr-namespace:Syncfusion.Maui.Buttons;assembly=Syncfusion.Maui.Buttons"
             xmlns:vm="clr-namespace:Gastapp.ViewModels"
             x:DataType="vm:RegisterViewModel"
             xmlns:system="clr-namespace:System;assembly=System.Runtime"
             xmlns:models="clr-namespace:Gastapp.Models;assembly=Gastapp.Models">
    <Grid RowDefinitions="auto,*" Padding="20,12,20,0">
        <Border StrokeShape="RoundRectangle 14"
                StrokeThickness="0"
                BackgroundColor="{StaticResource SurfaceSecondary}"
                Padding="14,10">
            <Label FontSize="13"
                   FontFamily="OpenSansRegular"
                   TextColor="{StaticResource NavInactiveText}"
                   Text="Define tu frecuencia de ingreso, el día de pago y cuánto quieres ahorrar." />
        </Border>

        <ScrollView Grid.Row="1" Margin="0,14,0,0">
            <VerticalStackLayout Spacing="16" Padding="0,0,0,16">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Frecuencia de ingreso"
                           FontSize="14"
                           FontAttributes="Bold"
                           TextColor="{StaticResource TextDarkColor}" />

                    <Border StrokeShape="RoundRectangle 16"
                            StrokeThickness="1"
                            Stroke="{StaticResource BorderSubtle}"
                            BackgroundColor="{StaticResource SurfacePrimary}"
                            Padding="12,10">
                        <sf:SfRadioGroup Orientation="Horizontal"
                                         HorizontalOptions="Center"
                                         CheckedChanged="OnCheckedChanged">
                            <sf:SfRadioButton Text="Semanal"
                                              FontFamily="BalooRegular"
                                              IsChecked="{Binding IsWeekSelected}"/>
                            <sf:SfRadioButton Text="Quincenal"
                                              FontFamily="BalooRegular"
                                              IsChecked="{Binding IsBiWeekSelected}"/>
                            <sf:SfRadioButton Text="Mensual"
                                              FontFamily="BalooRegular"
                                              IsChecked="{Binding IsMonthSelected}"/>
                        </sf:SfRadioGroup>
                    </Border>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="8" IsVisible="{Binding IsWeekSelected}">
                    <Label Text="Selecciona el día de pago"
                           FontSize="13"
                           TextColor="{StaticResource NavInactiveText}" />
                    <CollectionView SelectionMode="Single"
                                    ItemsSource="{Binding ListForWeek}"
                                    SelectedItem="{Binding SelectedItemForWeek}"
                                    HeightRequest="140">
                        <CollectionView.ItemsLayout>
                            <GridItemsLayout Orientation="Vertical" Span="3" HorizontalItemSpacing="8" VerticalItemSpacing="8"/>
                        </CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:DayForWeek">
                                <Border Padding="8"
                                        StrokeShape="RoundRectangle 12"
                                        StrokeThickness="1.5"
                                        Stroke="{StaticResource BorderSubtle}"
                                        BackgroundColor="{StaticResource SurfacePrimary}">
                                    <VisualStateManager.VisualStateGroups>
                                        <VisualStateGroupList>
                                            <VisualStateGroup Name="CommonStates">
                                                <VisualState Name="Normal"/>
                                                <VisualState Name="Selected">
                                                    <VisualState.Setters>
                                                        <Setter Property="Stroke" Value="{StaticResource ButtonsGreen}"/>
                                                        <Setter Property="BackgroundColor" Value="{StaticResource AccentSoft}"/>
                                                    </VisualState.Setters>
                                                </VisualState>
                                            </VisualStateGroup>
                                        </VisualStateGroupList>
                                    </VisualStateManager.VisualStateGroups>
                                    <Label Text="{Binding DayName}"
                                           FontSize="13"
                                           HorizontalTextAlignment="Center"
                                           TextColor="{StaticResource TextDarkColor}"/>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="8" IsVisible="{Binding IsMonthOrBiWeekSelected}">
                    <Label Text="Selecciona día(s) de pago"
                           FontSize="13"
                           TextColor="{StaticResource NavInactiveText}" />
                    <Label Text="Quincenal: hasta 2 días. Mensual: solo 1 día."
                           FontSize="12"
                           TextColor="{StaticResource Gray500}" />
                    <CollectionView SelectionMode="Multiple"
                                    ItemsSource="{Binding ListForMonth}"
                                    SelectedItems="{Binding SelectedItemsForMonthOrBiweek, Mode=TwoWay}"
                                    SelectionChanged="SelectableItemsView_OnSelectionChanged"
                                    HeightRequest="200">
                        <CollectionView.ItemsLayout>
                            <GridItemsLayout Orientation="Vertical" Span="7" HorizontalItemSpacing="8" VerticalItemSpacing="8"/>
                        </CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="system:Int32">
                                <Border Padding="0"
                                        HeightRequest="38"
                                        WidthRequest="38"
                                        StrokeShape="RoundRectangle 10"
                                        StrokeThickness="1.5"
                                        Stroke="{StaticResource BorderSubtle}"
                                        BackgroundColor="{StaticResource SurfacePrimary}">
                                    <VisualStateManager.VisualStateGroups>
                                        <VisualStateGroupList>
                                            <VisualStateGroup Name="CommonStates">
                                                <VisualState Name="Normal"/>
                                                <VisualState Name="Selected">
                                                    <VisualState.Setters>
                                                        <Setter Property="Stroke" Value="{StaticResource ButtonsGreen}"/>
                                                        <Setter Property="BackgroundColor" Value="{StaticResource AccentSoft}"/>
                                                    </VisualState.Setters>
                                                </VisualState>
                                            </VisualStateGroup>
                                        </VisualStateGroupList>
                                    </VisualStateManager.VisualStateGroups>
                                    <Label Text="{Binding .}"
                                           FontSize="14"
                                           FontAttributes="Bold"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center"
                                           TextColor="{StaticResource TextDarkColor}"/>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>

                <BoxView HeightRequest="1"
                         BackgroundColor="{StaticResource BorderSubtle}" />

                <VerticalStackLayout Spacing="8">
                    <Label Text="Tus ingresos por período"
                           FontSize="14"
                           FontAttributes="Bold"
                           TextColor="{StaticResource TextDarkColor}" />
                    <Border StrokeShape="RoundRectangle 14"
                            StrokeThickness="1.5"
                            Stroke="{StaticResource BorderSubtle}"
                            BackgroundColor="{StaticResource SurfaceSecondary}"
                            Padding="12,0">
                        <Grid ColumnDefinitions="auto,*" ColumnSpacing="8">
                            <Label Text="$"
                                   VerticalOptions="Center"
                                   FontSize="20"
                                   TextColor="{StaticResource NavInactiveText}"/>
                            <Entry Grid.Column="1"
                                   Keyboard="Numeric"
                                   Text="{Binding Salary}"
                                   ReturnType="Next"
                                   Placeholder="0.00"
                                   HorizontalTextAlignment="End"
                                   FontSize="26"
                                   FontFamily="BalooRegular"
                                   TextColor="{StaticResource TextDarkColor}"/>
                        </Grid>
                    </Border>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="8">
                    <Label Text="Porcentaje de ahorro"
                           FontSize="14"
                           FontAttributes="Bold"
                           TextColor="{StaticResource TextDarkColor}" />
                    <Border StrokeShape="RoundRectangle 14"
                            StrokeThickness="1.5"
                            Stroke="{StaticResource BorderSubtle}"
                            BackgroundColor="{StaticResource SurfaceSecondary}"
                            Padding="12,0">
                        <Grid ColumnDefinitions="*,auto" ColumnSpacing="8">
                            <Entry Grid.Column="0"
                                   Keyboard="Numeric"
                                   Text="{Binding PercentSave}"
                                   ReturnType="Done"
                                   Placeholder="10"
                                   HorizontalTextAlignment="End"
                                   FontSize="24"
                                   FontFamily="BalooRegular"
                                   TextColor="{StaticResource TextDarkColor}"/>
                            <Label Grid.Column="1"
                                   Text="%"
                                   VerticalOptions="Center"
                                   FontSize="18"
                                   TextColor="{StaticResource NavInactiveText}"/>
                        </Grid>
                    </Border>
                </VerticalStackLayout>

                <Border BackgroundColor="{StaticResource AccentSoft}"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 16"
                        Padding="14,12">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="{Binding PercentSave, StringFormat='Al ahorrar un {0}% de tu salario'}"
                               FontAttributes="Bold"
                               TextColor="{StaticResource TextDarkColor}" />
                        <Label Text="{Binding TotalSave, StringFormat='Estarías ahorrando ${0:N2} por período'}"
                               FontFamily="OpenSansRegular"
                               TextColor="{StaticResource TextDarkColor}" />
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentView>